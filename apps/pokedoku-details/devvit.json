{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "pokedoku-details",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onCommentCreate": "/internal/triggers/on-comment-create",
    "onCommentUpdate": "/internal/triggers/on-comment-update",
    "onPostCreate": "/internal/triggers/on-post-create",
    "onPostUpdate": "/internal/triggers/on-post-update"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "www.pokedoku-helper.com"
      ]
    },
    "reddit": true
  },
  "dev": {
    "subreddit": "pokedoku_details_dev"
  }
}
