{
  "name": "pokedoku-helper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix astro run dev",
    "build": "npm run fetch-pokemon && npm --prefix astro run build",
    "build:daily-puzzle-lambda": "mkdir -p dist-lambda && npx esbuild terraform/lambda/daily-puzzle-fetcher.ts --bundle --platform=node --target=node20 --format=cjs --external:@aws-sdk/* --outfile=dist-lambda/daily-puzzle-fetcher.js",
    "package:daily-puzzle-lambda": "npm run build:daily-puzzle-lambda && zip -j dist-lambda/daily-puzzle-fetcher.zip dist-lambda/daily-puzzle-fetcher.js",
    "build:puzzle-statistics-lambda": "mkdir -p dist-lambda && npx esbuild terraform/lambda/puzzle-statistics.ts --bundle --platform=node --target=node20 --format=cjs --external:@aws-sdk/* --outfile=dist-lambda/puzzle-statistics.js",
    "package:puzzle-statistics-lambda": "npm run build:puzzle-statistics-lambda && zip -j dist-lambda/puzzle-statistics.zip dist-lambda/puzzle-statistics.js",
    "generate:puzzle-stats:local": "tsx scripts/generate-puzzle-statistics.ts",
    "fetch-today-puzzle": "tsx scripts/fetch-today-puzzle.ts",
    "lint": "eslint .",
    "preview": "npm --prefix astro run preview",
    "fetch-pokemon": "tsx scripts/fetch.ts",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.1.4"
  }
}
