{
  "name": "pokedoku-helper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run fetch-pokemon && npm run fetch-today-puzzle && tsc -b && vite build",
    "build:github": "npm run fetch-pokemon && npm run fetch-today-puzzle && tsc -b && vite build --base=/pokedoku-solver/ && rm -rf docs && mv dist docs",
    "fetch-today-puzzle": "tsx scripts/fetch-today-puzzle.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "fetch-pokemon": "tsx scripts/fetch.ts",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.1.4"
  }
}
