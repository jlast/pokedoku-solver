---
import { DEFAULT_OG_IMAGE, SITE_NAME, absoluteUrl } from "../lib/site";
import "../styles/index.css";

interface Props {
  title: string;
  description: string;
  path: string;
}

const { title, description, path } = Astro.props;
const canonical = absoluteUrl(path);
const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID;
const hasGoogleAnalytics = Boolean(googleAnalyticsId);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon-64.png" sizes="64x64" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={DEFAULT_OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={DEFAULT_OG_IMAGE} />
    <link rel="canonical" href={canonical} />
    <script is:inline>
      try {
        const storedTheme = window.localStorage.getItem("theme-mode");
        if (storedTheme === "light" || storedTheme === "dark") {
          document.documentElement.setAttribute("data-theme", storedTheme);
        }
      } catch {
        // Ignore storage access errors.
      }
    </script>
    {
      googleAnalyticsId ? (
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}
        ></script>
      ) : null
    }
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function(){window.dataLayer.push(arguments);};
      window.pokedokuAnalytics = window.pokedokuAnalytics || {};

      window.pokedokuAnalytics.serializeMetadata = function (metadata) {
        if (!metadata) return undefined;

        const entries = Object.entries(metadata).flatMap(([key, value]) => {
          if (value == null) return [];
          if (Array.isArray(value)) return [[key, value.join(",")]];
          if (typeof value === "boolean") return [[key, value ? "true" : "false"]];
          return [[key, value]];
        });

        return entries.length > 0 ? Object.fromEntries(entries) : undefined;
      };

      window.pokedokuAnalytics.getNormalizedPath = function (path) {
        if (path.startsWith("/pokemon/")) {
          return "/pokemon/***";
        }

        if (path.startsWith("/tools/category/")) {
          const parts = path.split("/").filter(Boolean);

          if (parts.length === 3) return "/tools/category/*";
          if (parts.length === 4) return "/tools/category/*/*";

          return "/tools/category/***";
        }

        return path;
      };

      window.pokedokuAnalytics.getRouteMetadata = function (path) {
        const parts = path.split("/").filter(Boolean);

        if (parts[0] === "pokemon" && parts[1]) {
          return {
            route_type: "pokemon",
            pokemon_slug: parts.slice(1).join("/")
          };
        }

        if (parts[0] === "tools" && parts[1] === "category" && parts[2]) {
          return {
            route_type: "category",
            category_slug: parts[2],
            subcategory_slug: parts[3] || undefined
          };
        }

        return {};
      };

      window.pokedokuAnalytics.trackEvent = function (name, metadata, callback) {
        if (typeof window.gtag !== "function") {
          if (callback) callback();
          return;
        }

        const serializedMetadata = window.pokedokuAnalytics.serializeMetadata(metadata) || {};
        const pathname = window.location.pathname;

        if (name === "page_view") {
          Object.assign(serializedMetadata, {
            page_path: window.pokedokuAnalytics.getNormalizedPath(pathname),
            page_location: window.location.href,
            page_title: document.title,
            raw_path: pathname,
            ...window.pokedokuAnalytics.getRouteMetadata(pathname),
          });
        }

        window.gtag("event", name, serializedMetadata);
        if (callback) callback();
      };
    </script>
    {
      hasGoogleAnalytics ? (
        <script is:inline define:vars={{ googleAnalyticsId }}>
          window.gtag("js", new Date());
          window.gtag("config", googleAnalyticsId, {
            send_page_view: false,
          });
        </script>
      ) : null
    }
  </head>
  <body>
    <slot />
  </body>
</html>
