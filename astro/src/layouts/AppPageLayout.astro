---
import { DEFAULT_OG_IMAGE, SITE_NAME, absoluteUrl } from "../lib/site";
import "../styles/App.css";
import "../styles/index.css";

interface Props {
  title: string;
  description: string;
  path: string;
}

const { title, description, path } = Astro.props;
const canonical = absoluteUrl(path);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon-64.png" sizes="64x64" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={DEFAULT_OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={DEFAULT_OG_IMAGE} />
    <link rel="canonical" href={canonical} />
    <script>window.sa_event=window.sa_event||function(){var a=[].slice.call(arguments);window.sa_event.q?window.sa_event.q.push(a):window.sa_event.q=[a]};</script>
  </head>
  <body>
    <slot />
<script is:inline>
  window.myPathOverwriter = function ({ path }) {
    if (path.startsWith("/pokemon/")) {
      return "/pokemon/***";
    }

    if (path.startsWith("/category/")) {
      const parts = path.split("/").filter(Boolean);

      if (parts.length === 2) return "/category/*";
      if (parts.length === 3) return "/category/*/*";

      return "/category/***";
    }

    return path;
  };

  window.myMetadataCollector = function ({ type, path }) {
    if (type !== "pageview") return {};

    const originalPath = window.location.pathname;
    const parts = originalPath.split("/").filter(Boolean);

    if (parts[0] === "pokemon" && parts[1]) {
      return {
        route_type: "pokemon",
        pokemon_slug: parts.slice(1).join("/")
      };
    }

    if (parts[0] === "category" && parts[1]) {
      return {
        route_type: "category",
        category_slug: parts[1],
        subcategory_slug: parts[2] || undefined
      };
    }

    return {};
  };
</script>

<script
  is:inline
  async
  data-collect-dnt="true"
  data-path-overwriter="myPathOverwriter"
  data-metadata-collector="myMetadataCollector"
  src="https://scripts.simpleanalyticscdn.com/latest.js"
></script>
  </body>
</html>
