---
import AppPageLayout from "../../../layouts/AppPageLayout.astro";
import { Header } from "../../../app/components/Header";
import { Footer } from "../../../app/components/Footer";
import { CategoryBadgeLink } from "../../../app/components/shared/CategoryBadgeLink";
import { parseCategoryId } from "../../../app/components/puzzle-stats/categoryUtils";
import CategoryIconBadge from "../../../components/CategoryIconBadge.astro";
import CategorySidebar from "../../../components/category/CategorySidebar.astro";
import CategoryPokemonExamplesCard from "../../../components/category/CategoryPokemonExamplesCard.astro";
import CategoryDifficultyDonutCard from "../../../components/category/CategoryDifficultyDonutCard.astro";
import CategoryPairHistoryTimelineCard from "../../../app/components/category/CategoryPairHistoryTimelineCard";
import { DEX_DIFFICULTY_COLORS } from "../../../../../lib/shared/constants";
import {
  canonicalizePairSlugs,
  getCategories,
  getCategoryPairs,
  getCategoryPairBySlugMap,
  type CategoryPageData,
} from "../../../lib/data";

export function getStaticPaths() {
  const seen = new Set<string>();
  const paths: Array<{ params: { left: string; right: string } }> = [];

  for (const pair of getCategoryPairs()) {
    const variants: Array<{ left: string; right: string }> = [
      { left: pair.left.slug, right: pair.right.slug },
      { left: pair.right.slug, right: pair.left.slug },
    ];

    for (const variant of variants) {
      const key = `${variant.left}::${variant.right}`;
      if (seen.has(key)) continue;
      seen.add(key);
      paths.push({ params: variant });
    }
  }

  return paths;
}

const left = Astro.params.left ?? "";
const right = Astro.params.right ?? "";
const canonicalSlug = canonicalizePairSlugs(left, right);

if (!canonicalSlug) {
  return Astro.redirect("/puzzle-stats/");
}

const [canonicalLeft, canonicalRight] = canonicalSlug.split("-x-");
if (!canonicalLeft || !canonicalRight) {
  return Astro.redirect("/puzzle-stats/");
}

if (left !== canonicalLeft || right !== canonicalRight) {
  return Astro.redirect(`/category/${canonicalLeft}/${canonicalRight}/`, 301);
}

const pair = getCategoryPairBySlugMap().get(canonicalSlug) ?? null;
if (pair === null) {
  return Astro.redirect("/puzzle-stats/");
}
const resolvedPair = pair;

const categories = getCategories();
const categoryTypeOrder: Record<string, number> = {
  types: 0,
  regions: 1,
  evolution: 2,
  category: 3,
};

const categoriesByType = [...categories].sort((a, b) => {
  const parsedA = parseCategoryId(a.key);
  const parsedB = parseCategoryId(b.key);
  const typeRankA = categoryTypeOrder[parsedA.type] ?? 99;
  const typeRankB = categoryTypeOrder[parsedB.type] ?? 99;

  if (typeRankA !== typeRankB) return typeRankA - typeRankB;
  if (b.count !== a.count) return b.count - a.count;
  return a.label.localeCompare(b.label);
});

const categoryTypeLabel: Record<string, string> = {
  types: "Types",
  regions: "Regions",
  evolution: "Evolution",
  category: "Categories",
};

const groupedCategories = categoriesByType.reduce<
  Array<{ type: string; label: string; items: CategoryPageData[] }>
>((groups, item) => {
  const parsed = parseCategoryId(item.key);
  const type = parsed.type || "other";
  const group = groups.find((entry) => entry.type === type);

  if (group) {
    group.items.push(item);
  } else {
    groups.push({
      type,
      label: categoryTypeLabel[type] ?? "Other",
      items: [item],
    });
  }

  return groups;
}, []);

const difficultyRank: Record<string, number> = {
  Impossible: 6,
  Nightmare: 5,
  Expert: 4,
  Hard: 3,
  Normal: 2,
  Easy: 1,
};

const pokemonSortedByDifficulty = [...pair.pokemon].sort((a, b) => {
  const rankA = a.dexDifficulty ? (difficultyRank[a.dexDifficulty] ?? 0) : 0;
  const rankB = b.dexDifficulty ? (difficultyRank[b.dexDifficulty] ?? 0) : 0;
  if (rankB !== rankA) return rankB - rankA;

  const percentileA = typeof a.dexDifficultyPercentile === "number" ? a.dexDifficultyPercentile : -1;
  const percentileB = typeof b.dexDifficultyPercentile === "number" ? b.dexDifficultyPercentile : -1;
  if (percentileB !== percentileA) return percentileB - percentileA;

  return a.name.localeCompare(b.name);
});

type DifficultyEntry = {
  difficulty: string;
  percentile: number;
};

const percentileDifficultyEntries: DifficultyEntry[] = [];
for (const entry of resolvedPair.pokemon) {
  if (typeof entry.dexDifficulty === "string" && typeof entry.dexDifficultyPercentile === "number") {
    percentileDifficultyEntries.push({
      difficulty: entry.dexDifficulty,
      percentile: entry.dexDifficultyPercentile,
    });
  }
}

const averagePercentile =
  percentileDifficultyEntries.length > 0
    ? percentileDifficultyEntries.reduce((sum, entry) => sum + entry.percentile, 0) / percentileDifficultyEntries.length
    : null;

function modeDifficulty(): string | null {
  const counts = new Map<string, number>();
  for (const entry of resolvedPair.pokemon) {
    if (!entry.dexDifficulty) continue;
    counts.set(entry.dexDifficulty, (counts.get(entry.dexDifficulty) ?? 0) + 1);
  }

  let best: string | null = null;
  let bestCount = -1;
  for (const [difficulty, count] of counts.entries()) {
    if (count > bestCount) {
      best = difficulty;
      bestCount = count;
    }
  }

  return best;
}

function formatAverageDifficulty(): string {
  if (averagePercentile === null) {
    return modeDifficulty() ?? "Unknown";
  }

  const closest = percentileDifficultyEntries.reduce((best, current) => {
    const bestDistance = Math.abs(best.percentile - averagePercentile);
    const currentDistance = Math.abs(current.percentile - averagePercentile);

    if (currentDistance < bestDistance) return current;
    if (currentDistance > bestDistance) return best;
    return current.percentile > best.percentile ? current : best;
  });

  return closest.difficulty;
}

const averageDifficultyLabel = formatAverageDifficulty();
const averageDifficultyColor = DEX_DIFFICULTY_COLORS[averageDifficultyLabel] ?? "#64748b";

const parsedLeftCategory = parseCategoryId(resolvedPair.left.key);
const parsedRightCategory = parseCategoryId(resolvedPair.right.key);

let query = "";

if (resolvedPair.left.type === resolvedPair.right.type) {
  // Same type → comma-separated
  query = `${resolvedPair.left.type}=${encodeURIComponent(resolvedPair.left.label)},${encodeURIComponent(resolvedPair.right.label)}`;
} else {
  // Different types → separate params
  query = `${resolvedPair.left.type}=${encodeURIComponent(resolvedPair.left.label)}&${resolvedPair.right.type}=${encodeURIComponent(resolvedPair.right.label)}`;
}

const seeAllHref = `/pokemon-list/?sortBy=difficulty-asc&${query}`;

---

<AppPageLayout
  title={`${resolvedPair.left.label} & ${resolvedPair.right.label} Pokemon List | Pokedoku Helper`}
  description={`Pokemon that satisfy both ${resolvedPair.left.label} and ${resolvedPair.right.label}.`}
  path={`/category/${resolvedPair.left.slug}/${resolvedPair.right.slug}/`}
>
  <div id="root">
    <div class="app min-h-screen px-4 py-6">
      <Header
        title={`${resolvedPair.left.label} & ${resolvedPair.right.label}`}
        currentPage="category"
        client:load
      />

      <main class="mx-auto w-full max-w-6xl px-2 pb-10">
        <section class="grid grid-cols-1 items-start gap-4 lg:grid-cols-[300px_1fr]">
          <CategorySidebar groups={groupedCategories} activeSlug={[resolvedPair.left.slug, resolvedPair.right.slug]} />

          <div class="grid gap-4">
            <section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-[0_18px_34px_rgba(15,23,42,0.08)]">
              <div class="mt-1 flex flex-wrap items-center gap-2.5">
                <CategoryIconBadge parsed={parsedLeftCategory} />
                <h1 class="m-0 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">{resolvedPair.left.label}</h1>
                <span class="text-slate-400">+</span>
                <CategoryIconBadge parsed={parsedRightCategory} />
                <h1 class="m-0 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">{resolvedPair.right.label}</h1>
              </div>
              <div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-3">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2">
                  <p class="m-0 text-xs uppercase tracking-[0.12em] text-slate-500">Matching Pokemon</p>
                  <p class="m-0 mt-1 text-sm font-semibold text-slate-900">{String(resolvedPair.count)}</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2">
                  <p class="m-0 text-xs uppercase tracking-[0.12em] text-slate-500">Last appeared</p>
                  <p id="pair-last-appeared" class="m-0 mt-1 text-sm font-semibold text-slate-900">Loading...</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2">
                  <p class="m-0 text-xs uppercase tracking-[0.12em] text-slate-500">Average Difficulty</p>
                  <span class="mt-1 inline-flex items-center rounded-full px-2 py-1 text-xs font-semibold text-white" style={`background-color: ${averageDifficultyColor}`}>
                    {averageDifficultyLabel}
                  </span>
                </div>
              </div>
            </section>

            <CategoryPokemonExamplesCard
              pokemon={pokemonSortedByDifficulty}
              category={resolvedPair.left.label}
              categoryType={resolvedPair.left.type}
              seeAllHref={seeAllHref}
            />

            <CategoryPairHistoryTimelineCard pairSlug={canonicalSlug} client:load />

            <CategoryDifficultyDonutCard pokemon={resolvedPair.pokemon} />
          </div>
        </section>
      </main>

      <Footer client:load />
    </div>
  </div>
  <script is:inline define:vars={{ canonicalSlug }}>
    (() => {
      const pairSlug = canonicalSlug;
      const target = document.getElementById("pair-last-appeared");
      if (!target) return;

      const formatDate = (value) => {
        const [year, month, day] = value.split("-").map(Number);
        const date = Number.isFinite(year) && Number.isFinite(month) && Number.isFinite(day)
          ? new Date(year, month - 1, day)
          : new Date(value);
        if (Number.isNaN(date.getTime())) return value;
        return new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" }).format(date);
      };

      fetch(`/data/runtime/category-pairs/${pairSlug}-stats.json?t=${Date.now()}`)
        .then((res) => (res.ok ? res.json() : null))
        .then((data) => {
          const date = typeof data?.lastAppeared?.date === "string"
            ? data.lastAppeared.date
            : Array.isArray(data?.appearanceDates) && data.appearanceDates.length > 0
              ? data.appearanceDates[0]
              : null;
          target.textContent = date ? formatDate(date) : "Unknown";
        })
        .catch(() => {
          target.textContent = "Unknown";
        });
    })();
  </script>
</AppPageLayout>
