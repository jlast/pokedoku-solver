---
import AppPageLayout from "../../layouts/AppPageLayout.astro";
import { Header } from "../../app/components/Header";
import { Footer } from "../../app/components/Footer";

const PRESTIGE_LEVELS = [
  {
    id: "pokeball",
    label: "Poké Ball",
    oddsLabel: "1 / 100",
    chance: 0.01,
    icon: "🔴",
    description: "Base shiny chance per eligible square.",
  },
  {
    id: "greatball",
    label: "Great Ball",
    oddsLabel: "TBD",
    chance: null,
    icon: "🔵",
    description: "Add the final rate when confirmed.",
  },
  {
    id: "ultraball",
    label: "Ultra Ball",
    oddsLabel: "TBD",
    chance: null,
    icon: "🟡",
    description: "Add the final rate when confirmed.",
  },
  {
    id: "masterball",
    label: "Master Ball",
    oddsLabel: "TBD",
    chance: null,
    icon: "🟣",
    description: "Add the final rate when confirmed.",
  },
];

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What does this calculator show?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "It shows your odds of getting a chosen number of shiny Pokémon across one or more Pokedoku grids.",
      },
    },
    {
      "@type": "Question",
      name: "Does it calculate exact or minimum shinies?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "By default, it calculates at least X shinies. You can switch to exactly X shinies.",
      },
    },
    {
      "@type": "Question",
      name: "What is the default setup?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The default is 2 shinies across 1 grid of 9 squares at Poké Ball prestige, with a 1 in 100 shiny chance per eligible square.",
      },
    },
    {
      "@type": "Question",
      name: "Why are the odds so low?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Each square has an independent shiny roll, so even 9 squares at 1 in 100 only gives a small chance of multiple shinies.",
      },
    },
  ],
};
---

<AppPageLayout
  title="Shiny Odds Calculator for Pokedoku"
  description="Calculate your chance of finding shiny Pokémon across Pokedoku grids by shiny target, number of grids, and prestige level."
  path="/shiny-odds-calculator/"
>
  <div class="app">
    <Header
      title="✨ Shiny Odds Calculator"
      subtitle="Calculate your chance of finding shiny Pokémon across Pokedoku grids."
      currentPage="shiny-odds-calculator"
      client:load
    />

    <main class="content-section flex flex-col gap-4 sm:gap-5">
      <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)}></script>

      <section class="rounded-[18px] border border-slate-200 bg-white p-4 shadow-sm sm:p-5" aria-labelledby="calculator-title">
        <div class="mb-4 flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-50 text-xl text-indigo-600">🧮</div>
          <div>
            <h2 id="calculator-title" class="m-0 text-xl font-bold text-slate-900">Your setup</h2>
            <p class="m-0 text-sm text-slate-500">Start with the default 2 shinies out of 9 squares.</p>
          </div>
        </div>

        <div class="grid gap-3">
          <label class="calculator-row" for="shinies-wanted">
            <span class="calculator-icon bg-violet-50 text-violet-600">✨</span>
            <span class="min-w-0 flex-1">
              <span class="block font-semibold text-slate-900">Shinies wanted</span>
              <span class="block text-sm text-slate-500">How many shiny Pokémon?</span>
            </span>
            <span class="stepper" data-stepper="shinies-wanted">
              <button type="button" data-step="-1" aria-label="Decrease shinies wanted">−</button>
              <input id="shinies-wanted" data-calculator-input="shinies" type="number" min="0" step="1" value="2" inputmode="numeric" />
              <button type="button" data-step="1" aria-label="Increase shinies wanted">+</button>
            </span>
          </label>

          <label class="calculator-row" for="squares-per-grid">
            <span class="calculator-icon bg-sky-50 text-sky-600">▦</span>
            <span class="min-w-0 flex-1">
              <span class="block font-semibold text-slate-900">Squares per grid</span>
              <span class="block text-sm text-slate-500">How many squares in each grid?</span>
            </span>
            <span class="stepper" data-stepper="squares-per-grid">
              <button type="button" data-step="-1" aria-label="Decrease squares per grid">−</button>
              <input id="squares-per-grid" data-calculator-input="squares" type="number" min="1" step="1" value="9" inputmode="numeric" />
              <button type="button" data-step="1" aria-label="Increase squares per grid">+</button>
            </span>
          </label>

          <label class="calculator-row" for="grid-count">
            <span class="calculator-icon bg-emerald-50 text-emerald-600">↪</span>
            <span class="min-w-0 flex-1">
              <span class="block font-semibold text-slate-900">Number of grids</span>
              <span class="block text-sm text-slate-500">How many grids are you completing?</span>
            </span>
            <span class="stepper" data-stepper="grid-count">
              <button type="button" data-step="-1" aria-label="Decrease number of grids">−</button>
              <input id="grid-count" data-calculator-input="grids" type="number" min="1" step="1" value="1" inputmode="numeric" />
              <button type="button" data-step="1" aria-label="Increase number of grids">+</button>
            </span>
          </label>

          <label class="calculator-row" for="prestige-level">
            <span class="calculator-icon bg-rose-50 text-rose-600">🔴</span>
            <span class="min-w-0 flex-1">
              <span class="block font-semibold text-slate-900">Prestige level</span>
              <span class="block text-sm text-slate-500">Shiny odds per eligible square</span>
            </span>
            <select id="prestige-level" data-calculator-input="prestige" class="select-input">
              {PRESTIGE_LEVELS.map((level) => (
                <option value={level.id} data-chance={level.chance ?? ""} selected={level.id === "pokeball"}>
                  {level.label} ({level.oddsLabel})
                </option>
              ))}
            </select>
          </label>

          <fieldset class="rounded-xl border border-slate-200 bg-slate-50 p-2">
            <legend class="sr-only">Result type</legend>
            <div class="grid grid-cols-2 gap-2">
              <label class="result-mode-pill">
                <input type="radio" name="result-mode" value="at-least" checked data-calculator-input="mode" />
                <span>At least X</span>
              </label>
              <label class="result-mode-pill">
                <input type="radio" name="result-mode" value="exactly" data-calculator-input="mode" />
                <span>Exactly X</span>
              </label>
            </div>
          </fieldset>

          <button type="button" class="primary-button" data-action="calculate">✨ Calculate odds</button>
          <button type="button" class="secondary-button" data-action="reset">↻ Reset defaults</button>
        </div>
      </section>

      <section class="rounded-[18px] border border-indigo-100 bg-gradient-to-br from-indigo-50 via-white to-violet-50 p-4 text-center shadow-sm sm:p-5" aria-live="polite">
        <div class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-full bg-violet-100 text-xl">✨</div>
        <p class="m-0 text-sm font-semibold text-slate-800" data-result-title>Chance of 2 or more shinies</p>
        <p class="my-2 text-5xl font-black tracking-tight text-indigo-600" data-result-main>2.66%</p>
        <p class="mx-auto mb-4 max-w-[36rem] text-sm text-slate-600" data-result-subtitle>Across 1 grid with 9 squares at Poké Ball prestige.</p>

        <dl class="overflow-hidden rounded-xl border border-slate-100 bg-white text-left shadow-sm">
          <div class="result-stat">
            <dt>▮ Expected shinies</dt>
            <dd data-result-expected>0.09</dd>
          </div>
          <div class="result-stat">
            <dt>⭐ Chance of exactly target</dt>
            <dd data-result-exact>0.31%</dd>
          </div>
          <div class="result-stat">
            <dt>🎯 Chance of at least 1</dt>
            <dd data-result-at-least-one>8.65%</dd>
          </div>
          <div class="result-stat">
            <dt>🛡 Chance of 0 shinies</dt>
            <dd data-result-zero>91.35%</dd>
          </div>
        </dl>

        <div class="mt-3 rounded-xl bg-indigo-50 px-4 py-3 text-left text-sm text-slate-700">
          <strong class="text-indigo-700">Total squares</strong>
          <span class="block" data-result-total>9 squares (1 grid × 9)</span>
        </div>
      </section>

      <aside class="flex gap-3 rounded-[14px] border border-sky-100 bg-sky-50 p-4 text-slate-700">
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-sky-500 font-bold text-white">i</span>
        <p class="m-0 text-sm leading-6">
          Shiny odds are calculated per eligible square. For “at least X shinies”, the calculator adds together all outcomes from X up to the total number of squares.
        </p>
      </aside>

      <section class="rounded-[18px] border border-slate-200 bg-white p-4 shadow-sm sm:p-5" aria-labelledby="prestige-title">
        <div class="mb-3 flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-50 text-xl">🔴</div>
          <div>
            <h2 id="prestige-title" class="m-0 text-xl font-bold text-slate-900">Prestige levels</h2>
            <p class="m-0 text-sm text-slate-500">Each prestige level has a different base shiny rate.</p>
          </div>
        </div>

        <div class="overflow-hidden rounded-xl border border-slate-200">
          {PRESTIGE_LEVELS.map((level) => (
            <button
              type="button"
              class:list={[
                "prestige-option",
                level.id === "pokeball" ? "is-selected" : "",
              ]}
              data-prestige-option={level.id}
              disabled={level.chance === null}
            >
              <span class="text-xl" aria-hidden="true">{level.icon}</span>
              <span class="flex-1 text-left">
                <span class="block font-semibold text-slate-900">{level.label}</span>
                <span class="block text-xs text-slate-500">{level.description}</span>
              </span>
              <span class="font-bold text-indigo-600">{level.oddsLabel}</span>
            </button>
          ))}
        </div>
      </section>

      <section class="rounded-[18px] border border-slate-200 bg-white p-4 shadow-sm sm:p-5" aria-labelledby="faq-title">
        <div class="mb-3 flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-violet-100 text-xl">?</div>
          <h2 id="faq-title" class="m-0 text-xl font-bold text-slate-900">FAQ</h2>
        </div>

        <div class="overflow-hidden rounded-xl border border-slate-200">
          <details class="faq-item" open>
            <summary>What does this calculator show?</summary>
            <p>It shows your odds of getting a chosen number of shiny Pokémon across one or more Pokedoku grids.</p>
          </details>
          <details class="faq-item">
            <summary>Does it calculate exact or minimum shinies?</summary>
            <p>By default, it calculates “at least X shinies.” You can switch to “exactly X shinies.”</p>
          </details>
          <details class="faq-item">
            <summary>What is the default setup?</summary>
            <p>The default is 2 shinies across 1 grid of 9 squares at Poké Ball prestige, with a 1/100 shiny chance per square.</p>
          </details>
          <details class="faq-item">
            <summary>Why are the odds so low?</summary>
            <p>Each square has an independent shiny roll, so even 9 squares at 1/100 only gives a small chance of multiple shinies.</p>
          </details>
        </div>
      </section>
    </main>

    <Footer client:load />
  </div>

  <style>
    .calculator-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.75rem;
      align-items: center;
      border: 1px solid rgb(226 232 240);
      border-radius: 0.875rem;
      padding: 0.75rem;
      background: rgb(248 250 252 / 0.65);
    }

    @media (min-width: 640px) {
      .calculator-row {
        grid-template-columns: auto minmax(0, 1fr) auto;
      }
    }

    .calculator-icon {
      display: flex;
      width: 2.75rem;
      height: 2.75rem;
      align-items: center;
      justify-content: center;
      border-radius: 0.75rem;
      font-weight: 800;
    }

    .stepper {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 2.75rem minmax(0, 1fr) 2.75rem;
      overflow: hidden;
      border: 1px solid rgb(203 213 225);
      border-radius: 0.75rem;
      background: white;
    }

    @media (min-width: 640px) {
      .stepper {
        grid-column: auto;
        width: 12rem;
      }
    }

    .stepper button,
    .stepper input {
      min-height: 2.75rem;
      border: 0;
      background: transparent;
      text-align: center;
      font-weight: 800;
      color: rgb(15 23 42);
    }

    .stepper button {
      cursor: pointer;
      font-size: 1.25rem;
    }

    .stepper input {
      border-inline: 1px solid rgb(226 232 240);
      appearance: textfield;
    }

    .stepper input::-webkit-outer-spin-button,
    .stepper input::-webkit-inner-spin-button {
      margin: 0;
      appearance: none;
    }

    .select-input {
      grid-column: 1 / -1;
      width: 100%;
      min-height: 2.9rem;
      border: 1px solid rgb(203 213 225);
      border-radius: 0.75rem;
      background: white;
      padding: 0 0.875rem;
      font-weight: 800;
      color: rgb(15 23 42);
    }

    @media (min-width: 640px) {
      .select-input {
        grid-column: auto;
        width: 14rem;
      }
    }

    .result-mode-pill span {
      display: flex;
      min-height: 2.5rem;
      cursor: pointer;
      align-items: center;
      justify-content: center;
      border-radius: 0.65rem;
      font-weight: 800;
      color: rgb(71 85 105);
    }

    .result-mode-pill input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .result-mode-pill input:checked + span {
      background: white;
      color: rgb(79 70 229);
      box-shadow: 0 1px 3px rgb(15 23 42 / 0.12);
    }

    .primary-button,
    .secondary-button {
      min-height: 3rem;
      border-radius: 0.75rem;
      font-weight: 800;
      transition: transform 120ms ease, box-shadow 120ms ease;
    }

    .primary-button {
      border: 0;
      background: linear-gradient(135deg, rgb(99 102 241), rgb(91 33 182));
      color: white;
      box-shadow: 0 10px 24px rgb(79 70 229 / 0.22);
    }

    .secondary-button {
      border: 1px solid rgb(203 213 225);
      background: white;
      color: rgb(79 70 229);
    }

    .primary-button:active,
    .secondary-button:active {
      transform: scale(0.99);
    }

    .result-stat {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      border-bottom: 1px solid rgb(226 232 240);
      padding: 0.85rem 1rem;
    }

    .result-stat:last-child {
      border-bottom: 0;
    }

    .result-stat dt {
      font-weight: 650;
      color: rgb(30 41 59);
    }

    .result-stat dd {
      margin: 0;
      font-weight: 900;
      color: rgb(15 23 42);
    }

    .prestige-option {
      display: flex;
      width: 100%;
      align-items: center;
      gap: 0.75rem;
      border: 0;
      border-bottom: 1px solid rgb(226 232 240);
      background: white;
      padding: 0.875rem 1rem;
    }

    .prestige-option:last-child {
      border-bottom: 0;
    }

    .prestige-option:not(:disabled) {
      cursor: pointer;
    }

    .prestige-option:disabled {
      opacity: 0.72;
    }

    .prestige-option.is-selected {
      background: rgb(238 242 255);
      box-shadow: inset 3px 0 0 rgb(99 102 241);
    }

    .faq-item {
      border-bottom: 1px solid rgb(226 232 240);
      background: white;
    }

    .faq-item:last-child {
      border-bottom: 0;
    }

    .faq-item summary {
      cursor: pointer;
      padding: 0.95rem 1rem;
      font-weight: 800;
      color: rgb(15 23 42);
    }

    .faq-item p {
      margin: 0;
      padding: 0 1rem 1rem;
      color: rgb(71 85 105);
      line-height: 1.65;
    }
  </style>

  <script>
    // @ts-nocheck
    const PRESTIGE_CHANCES = {
      pokeball: { label: "Poké Ball", chance: 0.01 },
      greatball: { label: "Great Ball", chance: null },
      ultraball: { label: "Ultra Ball", chance: null },
      masterball: { label: "Master Ball", chance: null },
    };

    const inputs = {
      shinies: document.querySelector('[data-calculator-input="shinies"]'),
      squares: document.querySelector('[data-calculator-input="squares"]'),
      grids: document.querySelector('[data-calculator-input="grids"]'),
      prestige: document.querySelector('[data-calculator-input="prestige"]'),
      modes: document.querySelectorAll('[data-calculator-input="mode"]'),
    };

    const results = {
      title: document.querySelector("[data-result-title]"),
      main: document.querySelector("[data-result-main]"),
      subtitle: document.querySelector("[data-result-subtitle]"),
      expected: document.querySelector("[data-result-expected]"),
      exact: document.querySelector("[data-result-exact]"),
      atLeastOne: document.querySelector("[data-result-at-least-one]"),
      zero: document.querySelector("[data-result-zero]"),
      total: document.querySelector("[data-result-total]"),
    };

    const clampNumber = (value, fallback, min) => {
      const parsed = Number.parseInt(value, 10);
      if (!Number.isFinite(parsed)) return fallback;
      return Math.max(min, parsed);
    };

    const factorialRatio = (n, k) => {
      let result = 1;
      for (let i = 1; i <= k; i += 1) {
        result *= (n - (k - i)) / i;
      }
      return result;
    };

    const binomial = (n, k, p) => {
      if (k < 0 || k > n) return 0;
      return factorialRatio(n, k) * p ** k * (1 - p) ** (n - k);
    };

    const atLeast = (n, k, p) => {
      if (k <= 0) return 1;
      if (k > n) return 0;
      let total = 0;
      for (let i = k; i <= n; i += 1) {
        total += binomial(n, i, p);
      }
      return total;
    };

    const formatPercent = (value) => {
      const percent = value * 100;
      if (percent >= 10) return `${percent.toFixed(1)}%`;
      if (percent >= 1) return `${percent.toFixed(2)}%`;
      return `${percent.toFixed(3)}%`;
    };

    const getMode = () => {
      const selected = Array.from(inputs.modes).find((input) => input.checked);
      return selected?.value ?? "at-least";
    };

    const trackEvent = (name, metadata) => {
      if (window.sa_loaded) {
        window.sa_event(name, metadata);
      }
    };

    const syncPrestigeButtons = (selectedId) => {
      document.querySelectorAll("[data-prestige-option]").forEach((button) => {
        button.classList.toggle("is-selected", button.getAttribute("data-prestige-option") === selectedId);
      });
    };

    const calculate = () => {
      const shinies = clampNumber(inputs.shinies.value, 2, 0);
      const squares = clampNumber(inputs.squares.value, 9, 1);
      const grids = clampNumber(inputs.grids.value, 1, 1);
      const prestige = PRESTIGE_CHANCES[inputs.prestige.value] ?? PRESTIGE_CHANCES.pokeball;
      const mode = getMode();
      const totalSquares = squares * grids;
      const chance = prestige.chance ?? PRESTIGE_CHANCES.pokeball.chance;
      const exactChance = binomial(totalSquares, shinies, chance);
      const mainChance = mode === "exactly" ? exactChance : atLeast(totalSquares, shinies, chance);
      const label = mode === "exactly" ? `exactly ${shinies}` : `${shinies} or more`;

      inputs.shinies.value = String(shinies);
      inputs.squares.value = String(squares);
      inputs.grids.value = String(grids);

      results.title.textContent = `Chance of ${label} shinies`;
      results.main.textContent = formatPercent(mainChance);
      results.subtitle.textContent = `Across ${grids} ${grids === 1 ? "grid" : "grids"} with ${totalSquares} squares at ${prestige.label} prestige.`;
      results.expected.textContent = (totalSquares * chance).toFixed(2);
      results.exact.textContent = formatPercent(exactChance);
      results.atLeastOne.textContent = formatPercent(atLeast(totalSquares, 1, chance));
      results.zero.textContent = formatPercent(binomial(totalSquares, 0, chance));
      results.total.textContent = `${totalSquares} ${totalSquares === 1 ? "square" : "squares"} (${grids} ${grids === 1 ? "grid" : "grids"} × ${squares})`;
      syncPrestigeButtons(inputs.prestige.value);
    };

    document.querySelectorAll("[data-stepper]").forEach((stepper) => {
      const input = stepper.querySelector("input");
      stepper.querySelectorAll("button").forEach((button) => {
        button.addEventListener("click", () => {
          const nextValue = clampNumber(input.value, Number(input.value || input.min || 0), Number(input.min || 0)) + Number(button.getAttribute("data-step"));
          input.value = String(Math.max(Number(input.min || 0), nextValue));
          calculate();
        });
      });
    });

    document.querySelectorAll("[data-calculator-input]").forEach((input) => {
      input.addEventListener("input", calculate);
      input.addEventListener("change", calculate);
    });

    document.querySelectorAll("[data-prestige-option]").forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.getAttribute("data-prestige-option");
        if (!id || button.disabled) return;
        inputs.prestige.value = id;
        calculate();
      });
    });

    document.querySelector('[data-action="calculate"]')?.addEventListener("click", () => {
      calculate();
      trackEvent("calculate_shiny_odds", {
        shinies: inputs.shinies.value,
        squares: inputs.squares.value,
        grids: inputs.grids.value,
        prestige: inputs.prestige.value,
        mode: getMode(),
      });
    });

    document.querySelector('[data-action="reset"]')?.addEventListener("click", () => {
      inputs.shinies.value = "2";
      inputs.squares.value = "9";
      inputs.grids.value = "1";
      inputs.prestige.value = "pokeball";
      document.querySelector('[name="result-mode"][value="at-least"]').checked = true;
      calculate();
      trackEvent("reset_shiny_odds", {});
    });

    calculate();
    trackEvent("view_shiny_odds_calculator", {});
  </script>
</AppPageLayout>
