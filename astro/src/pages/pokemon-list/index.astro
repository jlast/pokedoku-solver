---
import AppPageLayout from "../../layouts/AppPageLayout.astro";
import { Header } from "../../app/components/Header";
import { Footer } from "../../app/components/Footer";
---

<AppPageLayout
  title="Pokedoku Pokemon List – Browse All Pokemon with Filters"
  description="Browse all Pokemon with filters for types, regions, evolution, and categories."
  path="/pokemon-list/"
>
  <main class="mx-auto min-h-screen w-full max-w-6xl p-5" id="pokemon-list-app">
    <Header
      title="Pokemon List"
      subtitle="Browse all Pokemon with filters for types, regions, categories, and more."
      currentPage="pokemon-list"
      client:load
    />

    <div class="my-5 rounded-[15px] border-b border-slate-200 bg-slate-50 p-4">
      <div class="mb-6 flex flex-col gap-3 rounded-xl border border-[var(--border)] bg-[var(--bg)] p-4">
        <input
          id="search-input"
          type="text"
          placeholder="Search by name, type, region, move, or ability..."
          class="w-full rounded-lg border-2 border-[var(--border)] bg-[var(--bg)] px-3.5 py-2.5 text-[0.95rem] text-[var(--text-h)] placeholder:text-[var(--text)] focus:border-[var(--accent)] focus:outline-none"
        />
      </div>

      <div class="mb-3 flex justify-start gap-3">
        <button class="inline-flex items-center gap-1.5 rounded-[10px] border-2 border-slate-500 bg-slate-500 px-[18px] py-2.5 text-[0.9rem] font-medium text-white transition-colors hover:border-slate-600 hover:bg-slate-600" id="open-filter-drawer" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z" />
          </svg>
          Filter
          <span class="rounded-[10px] bg-white px-1.5 py-0.5 text-xs font-semibold text-slate-500" id="active-filter-count" hidden>0</span>
        </button>
        <button class="inline-flex items-center gap-1.5 rounded-[10px] border-2 border-slate-200 bg-white px-[18px] py-2.5 text-[0.9rem] font-medium text-slate-600 transition-colors hover:border-slate-300 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50" id="clear-filters" type="button" disabled>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
          </svg>
          Clear filters
        </button>
      </div>

    </div>

    <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
      <div class="flex gap-2">
        <label class="flex items-center gap-1">
          <span class="text-[0.8rem] text-[#666]" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path
                d="M7 4v14m0 0-3-3m3 3 3-3M17 20V6m0 0-3 3m3-3 3 3"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span class="relative inline-flex items-center">
            <select class="cursor-pointer appearance-none rounded-md border border-[var(--border)] bg-[var(--bg)] py-1 pl-2 pr-7 text-xs text-[var(--text)]" id="sort-select" aria-label="Sort Pokemon list">
              <option value="number-asc">Pokemon # (low to high)</option>
              <option value="number-desc">Pokemon # (high to low)</option>
              <option value="name-asc">Name (A to Z)</option>
              <option value="name-desc">Name (Z to A)</option>
              <option value="difficulty-asc">Dex difficulty (hard to easy)</option>
              <option value="difficulty-desc">Dex difficulty (easy to hard)</option>
              <option value="recent-appearance">Recent appearance (oldest first)</option>
              <option value="recent-appearance-newest">Recent appearance (newest first)</option>
            </select>
            <span class="pointer-events-none absolute right-2 inline-flex items-center text-[#666]" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                <path
                  d="m6 9 6 6 6-6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </span>
        </label>
      </div>
      <div class="text-sm text-[var(--text)]" id="results-count">0 of 0 Pokemon</div>
    </div>

    <div class="px-4 py-8 text-center text-[var(--text)]" id="no-results" hidden>
      <p class="mb-4 text-[1.1rem]">No Pokemon match the selected filters.</p>
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(150px,1fr))] gap-3" id="pokemon-grid"></div>
    <div id="load-more-sentinel" aria-hidden="true"></div>

    <Footer client:load />

    <div class="fixed inset-0 z-[999] bg-black/50 opacity-0 transition-opacity duration-300 pointer-events-none" id="filter-drawer-overlay" hidden></div>
    <div class="fixed bottom-0 left-0 top-0 z-[1000] block w-[85%] max-w-80 -translate-x-full overflow-y-auto bg-[var(--bg)] opacity-0 transition-all duration-300 ease-out pointer-events-none" id="filter-drawer" hidden>
      <div class="sticky top-0 flex items-center justify-between border-b border-[var(--border)] bg-[var(--bg)] p-4">
        <span class="text-[1.1rem] font-semibold">Filters</span>
        <button class="cursor-pointer bg-transparent p-1 text-[var(--text)]" id="close-filter-drawer" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
          </svg>
        </button>
      </div>
      <div class="p-4">
        <div class="mb-4 block border-none bg-transparent p-0">
          <input
            id="search-input-drawer"
            type="text"
            placeholder="Search by name, type, region, move, or ability..."
            class="w-full rounded-lg border-2 border-[var(--border)] bg-[var(--bg)] px-3.5 py-2.5 text-[0.95rem] text-[var(--text-h)] placeholder:text-[var(--text)] focus:border-[var(--accent)] focus:outline-none"
          />
        </div>
        <div id="drawer-filters"></div>
      </div>
      <div class="sticky bottom-0 flex justify-center gap-3 border-t border-[var(--border)] bg-[var(--bg)] p-4">
        <button id="clear-filters-drawer" class="w-fit rounded-lg border-2 border-red-300 bg-white px-4 py-2 text-sm text-red-700 transition-colors hover:border-red-400 hover:bg-rose-50 hover:text-red-800 disabled:cursor-not-allowed disabled:border-slate-200 disabled:bg-slate-50 disabled:text-slate-400" type="button">Clear All</button>
      </div>
    </div>
  </main>

  <script>
    // @ts-nocheck
    import { FILTER_CATEGORIES, parseFiltersFromUrl, getActiveFilters, getFiltersForUrl, applyFilters } from "../../../../lib/shared/filters";
    import { DEX_DIFFICULTY_COLORS, TYPE_COLORS } from "../../../../lib/shared/constants";
    import { slugify } from "../../lib/slug";

    const INITIAL_RENDER_COUNT = 120;
    const RENDER_BATCH_SIZE = 80;
    const SEARCH_TRACK_DEBOUNCE_MS = 400;
    const SORT_OPTIONS = new Set(["number-asc", "number-desc", "name-asc", "name-desc", "difficulty-asc", "difficulty-desc", "recent-appearance", "recent-appearance-newest"]);

    const state = {
      pokemon: [],
      loading: true,
      sortBy: "number-asc",
      filters: Object.fromEntries(FILTER_CATEGORIES.map((cat) => [cat.key, []])),
      difficultyFilter: [],
      expandedFilters: new Set(),
      showFilterDrawer: false,
      searchQuery: "",
      lastTrackedSearchQuery: "",
      searchTrackTimeoutId: null,
      visibleCount: INITIAL_RENDER_COUNT,
      daysSinceLastUsableByKeyId: new Map(),
    };

    const els = {
      grid: document.getElementById("pokemon-grid"),
      drawerFilters: document.getElementById("drawer-filters"),
      searchInput: document.getElementById("search-input"),
      searchInputDrawer: document.getElementById("search-input-drawer"),
      sortSelect: document.getElementById("sort-select"),
      resultsCount: document.getElementById("results-count"),
      noResults: document.getElementById("no-results"),
      clearFilters: document.getElementById("clear-filters"),
      clearFiltersDrawer: document.getElementById("clear-filters-drawer"),
      openDrawer: document.getElementById("open-filter-drawer"),
      closeDrawer: document.getElementById("close-filter-drawer"),
      drawer: document.getElementById("filter-drawer"),
      drawerOverlay: document.getElementById("filter-drawer-overlay"),
      activeFilterCount: document.getElementById("active-filter-count"),
      loadMoreSentinel: document.getElementById("load-more-sentinel"),
    };

    const trackEvent = (name, metadata) => {
      if (window.sa_loaded) window.sa_event(name, metadata);
    };

    const parseDay = (dateString) => new Date(`${dateString}T00:00:00.000Z`).getTime();
    const toDaysSinceLastUsable = (item, latestPuzzleDate) => {
      if (typeof item.daysSinceLastUsable === "number") return item.daysSinceLastUsable;
      if (!item.lastUsableDate || !latestPuzzleDate) return null;
      return Math.floor((parseDay(latestPuzzleDate) - parseDay(item.lastUsableDate)) / (24 * 60 * 60 * 1000));
    };

    const matchesCategorySearch = (pokemon, query) =>
      FILTER_CATEGORIES.some((cat) =>
        cat.options.some((opt) => opt.name.toLowerCase().includes(query) && opt.filter(pokemon)),
      );

    const getFilteredPokemon = () => {
      let result = applyFilters(state.pokemon, state.filters);
      if (state.searchQuery.trim()) {
        const query = state.searchQuery.toLowerCase();
        result = result.filter((p) =>
          p.name.toLowerCase().includes(query) ||
          p.types.some((t) => t?.toLowerCase().includes(query)) ||
          p.region?.toLowerCase().includes(query) ||
          matchesCategorySearch(p, query),
        );
      }
      if (state.difficultyFilter.length > 0) {
        result = result.filter((p) => p.dexDifficulty && state.difficultyFilter.includes(p.dexDifficulty));
      }
      return result;
    };

    const getSortedPokemon = () => {
      const copy = [...getFilteredPokemon()];
      if (state.sortBy === "number-asc") return copy.sort((a, b) => a.id - b.id);
      if (state.sortBy === "number-desc") return copy.sort((a, b) => b.id - a.id);
      if (state.sortBy === "name-asc") return copy.sort((a, b) => a.name.localeCompare(b.name));
      if (state.sortBy === "name-desc") return copy.sort((a, b) => b.name.localeCompare(a.name));
      if (state.sortBy === "difficulty-asc") return copy.sort((a, b) => (b.dexDifficultyPercentile ?? 0) - (a.dexDifficultyPercentile ?? 0));
      if (state.sortBy === "difficulty-desc") return copy.sort((a, b) => (a.dexDifficultyPercentile ?? 0) - (b.dexDifficultyPercentile ?? 0));
      if (state.sortBy === "recent-appearance") {
        return copy.sort((a, b) => {
          const aDays = state.daysSinceLastUsableByKeyId.get(a.formId ?? a.id) ?? Number.POSITIVE_INFINITY;
          const bDays = state.daysSinceLastUsableByKeyId.get(b.formId ?? b.id) ?? Number.POSITIVE_INFINITY;
          if (bDays !== aDays) return bDays - aDays;
          return a.id - b.id;
        });
      }
      if (state.sortBy === "recent-appearance-newest") {
        return copy.sort((a, b) => {
          const aDays = state.daysSinceLastUsableByKeyId.get(a.formId ?? a.id) ?? Number.POSITIVE_INFINITY;
          const bDays = state.daysSinceLastUsableByKeyId.get(b.formId ?? b.id) ?? Number.POSITIVE_INFINITY;
          if (aDays !== bDays) return aDays - bDays;
          return a.id - b.id;
        });
      }
      return copy;
    };

    const setDrawerVisible = (visible) => {
      state.showFilterDrawer = visible;
      document.body.style.overflow = visible ? "hidden" : "";

      if (visible) {
        els.drawer.hidden = false;
        els.drawerOverlay.hidden = false;

        requestAnimationFrame(() => {
          els.drawer.classList.remove("-translate-x-full", "opacity-0", "pointer-events-none");
          els.drawer.classList.add("translate-x-0", "opacity-100");
          els.drawerOverlay.classList.remove("opacity-0", "pointer-events-none");
          els.drawerOverlay.classList.add("opacity-100");
        });
        return;
      }

      els.drawer.classList.remove("translate-x-0", "opacity-100");
      els.drawer.classList.add("-translate-x-full", "opacity-0", "pointer-events-none");
      els.drawerOverlay.classList.remove("opacity-100");
      els.drawerOverlay.classList.add("opacity-0", "pointer-events-none");

      window.setTimeout(() => {
        if (!state.showFilterDrawer) {
          els.drawer.hidden = true;
          els.drawerOverlay.hidden = true;
        }
      }, 300);
    };

    const syncUrl = () => {
      const params = getFiltersForUrl(state.filters);
      const trimmedSearch = state.searchQuery.trim();
      if (trimmedSearch) params.set("search", trimmedSearch);
      else params.delete("search");
      params.delete("difficulty");
      state.difficultyFilter.forEach((value) => params.append("difficulty", value));
      params.set("sortBy", state.sortBy);

      const newUrl = `${window.location.pathname}${params.toString() ? "?" + params.toString() : ""}`;
      window.history.replaceState({}, "", newUrl);

      const ogUrlEl = document.querySelector('meta[property="og:url"]');
      if (ogUrlEl) ogUrlEl.setAttribute("content", window.location.href);
    };

    const baseFilterGroupClass = "flex flex-col overflow-hidden mb-4 rounded-lg border border-[var(--border)]";
    const expandedFilterGroupClass = `${baseFilterGroupClass} expanded`;
    const filterHeaderClass = "flex w-full items-center gap-2 bg-[var(--bg)] px-3 py-2.5 text-left";
    const filterButtonsClass = "filter-buttons flex flex-wrap gap-1.5 p-3";
    const filterButtonClass = "rounded-2xl border-2 border-[var(--border)] bg-[var(--bg)] px-3 py-1.5 text-[0.8rem] font-medium text-[var(--text)] transition-all";
    const createTypeBadge = (typeName) => {
      const badge = document.createElement("span");
      badge.className = "rounded-[10px] px-2 py-0.5 text-[0.7rem] font-semibold text-white";
      badge.textContent = typeName;
      badge.style.backgroundColor = TYPE_COLORS[typeName] || "#64748b";
      return badge;
    };

    const renderPokemonGrid = () => {
      const sortedPokemon = getSortedPokemon();
      const visiblePokemon = sortedPokemon.slice(0, state.visibleCount);
      els.resultsCount.textContent = `${sortedPokemon.length} of ${state.pokemon.length} Pokemon`;
      els.noResults.hidden = sortedPokemon.length !== 0;

      els.grid.innerHTML = "";
      for (const p of visiblePokemon) {
        const pokemonKeyId = p.formId ?? p.id;
        const slug = `${slugify(p.name)}-${pokemonKeyId}`;
        const card = document.createElement("a");
        card.className = "flex min-h-[180px] cursor-pointer flex-col items-center rounded-xl border border-[var(--border)] bg-[var(--bg)] p-3 no-underline transition-all hover:border-[var(--accent-border)] hover:bg-[var(--accent-bg)]";
        card.href = `${import.meta.env.BASE_URL}pokemon/${slug}/`;
        card.addEventListener("click", () => {
          trackEvent("click_pokemon_detail", {
            name: p.name,
            id: p.id,
            form_id: `${p.formId}`,
            slug,
            from: "pokemon-list",
          });
        });

        if (p.sprite) {
          const img = document.createElement("img");
          img.src = p.sprite;
          img.alt = "";
          img.loading = "lazy";
          img.decoding = "async";
          img.className = "h-20 w-20 object-contain";
          card.appendChild(img);
        } else {
          const placeholder = document.createElement("div");
          placeholder.className = "h-20 w-20 rounded-full bg-[var(--code-bg)]";
          card.appendChild(placeholder);
        }

        const info = document.createElement("div");
        info.className = "flex w-full flex-col items-center gap-1";
        info.innerHTML = `<div class="text-center text-[0.9rem] font-semibold text-[var(--text-h)]">${p.name}</div><div class="text-[0.8rem] text-[#666]">#${p.id}</div>`;

        const typeWrap = document.createElement("div");
        typeWrap.className = "flex flex-wrap justify-center gap-1";
        p.types.forEach((typeName) => typeWrap.appendChild(createTypeBadge(typeName)));
        info.appendChild(typeWrap);

        if (p.dexDifficulty) {
          const difficulty = document.createElement("span");
          difficulty.className = "rounded-[10px] px-2 py-[2px] text-[0.65rem] font-semibold uppercase text-white";
          difficulty.textContent = p.dexDifficulty;
          difficulty.style.backgroundColor = DEX_DIFFICULTY_COLORS[p.dexDifficulty] || "#64748b";
          info.appendChild(difficulty);
        }

        card.appendChild(info);
        els.grid.appendChild(card);
      }
    };

    const renderFilterGroup = (container, cat, isDrawer) => {
      const isExpanded = isDrawer || state.expandedFilters.has(cat.key);
      const activeCount = state.filters[cat.key]?.length ?? 0;
      const group = document.createElement("div");
      group.className = isExpanded ? expandedFilterGroupClass : baseFilterGroupClass;

      const header = document.createElement("button");
      header.className = `${filterHeaderClass} ${isDrawer ? "rounded-lg border border-[var(--border)]" : "border-none"}`;
      header.type = "button";
      header.innerHTML = `<span class="text-[0.9rem] font-semibold text-[var(--text-h)]">${cat.label}</span>${activeCount > 0 ? `<span class="rounded-[10px] bg-[var(--accent)] px-1.5 py-0.5 text-[0.7rem] font-semibold text-white">${activeCount}</span>` : ""}${isDrawer ? "" : `<span class="ml-auto text-[0.7rem] text-[var(--text)]">${isExpanded ? "▼" : "▶"}</span>`}`;
      if (!isDrawer) {
        header.addEventListener("click", () => {
          if (state.expandedFilters.has(cat.key)) {
            state.expandedFilters.delete(cat.key);
            trackEvent("collapse_filter", { category: cat.key });
          } else {
            state.expandedFilters.add(cat.key);
            trackEvent("expand_filter", { category: cat.key });
          }
          renderFilters();
        });
      }
      group.appendChild(header);

      const buttons = document.createElement("div");
      buttons.className = filterButtonsClass;
      buttons.style.display = isExpanded ? "flex" : "none";
      for (const opt of cat.options) {
        const isActive = (state.filters[cat.key] ?? []).includes(opt.name);
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = filterButtonClass;
        btn.textContent = opt.name;
        if (isActive && opt.color) {
          btn.style.backgroundColor = opt.color;
          btn.style.borderColor = opt.color;
          btn.style.color = "white";
        }
        btn.addEventListener("click", () => {
          state.visibleCount = INITIAL_RENDER_COUNT;
          const current = state.filters[cat.key] ?? [];
          const isRemoving = current.includes(opt.name);
          const next = isRemoving ? current.filter((v) => v !== opt.name) : [...current, opt.name];
          state.filters[cat.key] = next;
          trackEvent("toggle_filter", {
            category: cat.key,
            value: opt.name,
            action: isRemoving ? "remove" : "add",
            activeCount: next.length,
          });
          applyAndRender();
        });
        buttons.appendChild(btn);
      }
      group.appendChild(buttons);
      container.appendChild(group);
    };

    const renderDifficultyFilter = (container, isDrawer) => {
      const isExpanded = isDrawer || state.expandedFilters.has("difficulty");
      const group = document.createElement("div");
      group.className = isExpanded ? expandedFilterGroupClass : baseFilterGroupClass;
      const count = state.difficultyFilter.length;
      const header = document.createElement("button");
      header.type = "button";
      header.className = `${filterHeaderClass} ${isDrawer ? "rounded-lg border border-[var(--border)]" : "border-none"}`;
      header.innerHTML = `<span class="text-[0.9rem] font-semibold text-[var(--text-h)]">Dex Difficulty</span>${count > 0 ? `<span class="rounded-[10px] bg-[var(--accent)] px-1.5 py-0.5 text-[0.7rem] font-semibold text-white">${count}</span>` : ""}${isDrawer ? "" : `<span class="ml-auto text-[0.7rem] text-[var(--text)]">${isExpanded ? "▼" : "▶"}</span>`}`;
      if (!isDrawer) {
        header.addEventListener("click", () => {
          if (state.expandedFilters.has("difficulty")) {
            state.expandedFilters.delete("difficulty");
            trackEvent("collapse_filter", { category: "difficulty" });
          } else {
            state.expandedFilters.add("difficulty");
            trackEvent("expand_filter", { category: "difficulty" });
          }
          renderFilters();
        });
      }
      group.appendChild(header);

      const buttons = document.createElement("div");
      buttons.className = filterButtonsClass;
      buttons.style.display = isExpanded ? "flex" : "none";
      Object.keys(DEX_DIFFICULTY_COLORS).forEach((diff) => {
        const isActive = state.difficultyFilter.includes(diff);
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = filterButtonClass;
        btn.textContent = diff;
        btn.style.borderColor = DEX_DIFFICULTY_COLORS[diff];
        btn.style.color = isActive ? "white" : DEX_DIFFICULTY_COLORS[diff];
        if (isActive) btn.style.backgroundColor = DEX_DIFFICULTY_COLORS[diff];
        btn.addEventListener("click", () => {
          state.visibleCount = INITIAL_RENDER_COUNT;
          state.difficultyFilter = isActive
            ? state.difficultyFilter.filter((d) => d !== diff)
            : [...state.difficultyFilter, diff];
          applyAndRender();
        });
        buttons.appendChild(btn);
      });
      group.appendChild(buttons);
      container.appendChild(group);
    };

    const renderFilters = () => {
      els.drawerFilters.innerHTML = "";
      renderDifficultyFilter(els.drawerFilters, true);
      for (const cat of FILTER_CATEGORIES) {
        renderFilterGroup(els.drawerFilters, cat, true);
      }
    };

    const updateControlState = () => {
      const activeCount = getActiveFilters(state.filters) + state.difficultyFilter.length;
      const hasActiveFilters = activeCount > 0 || state.searchQuery.trim().length > 0;
      els.clearFilters.disabled = !hasActiveFilters;
      els.activeFilterCount.hidden = activeCount === 0;
      els.activeFilterCount.textContent = `${activeCount}`;
      els.searchInput.value = state.searchQuery;
      els.searchInputDrawer.value = state.searchQuery;
      els.sortSelect.value = state.sortBy;
    };

    const applyAndRender = () => {
      syncUrl();
      renderFilters();
      renderPokemonGrid();
      updateControlState();

      const totalFilters = getActiveFilters(state.filters);
      if (totalFilters > 0) {
        const filterCounts = {};
        FILTER_CATEGORIES.forEach((cat) => { filterCounts[cat.key] = state.filters[cat.key]?.length ?? 0; });
        trackEvent("filter_change", { ...filterCounts, total: totalFilters });
      }
    };

    const trackSearchQuery = (source) => {
      if (state.searchTrackTimeoutId) window.clearTimeout(state.searchTrackTimeoutId);
      state.searchTrackTimeoutId = window.setTimeout(() => {
        const trimmedQuery = state.searchQuery.trim();
        if (!trimmedQuery) {
          if (state.lastTrackedSearchQuery) {
            trackEvent("clear_search_query", {
              source,
              previousQuery: state.lastTrackedSearchQuery,
            });
            state.lastTrackedSearchQuery = "";
          }
          return;
        }

        if (trimmedQuery === state.lastTrackedSearchQuery) return;
        state.lastTrackedSearchQuery = trimmedQuery;
        trackEvent("search_query", {
          source,
          query: trimmedQuery,
          length: trimmedQuery.length,
          results: getSortedPokemon().length,
        });
      }, SEARCH_TRACK_DEBOUNCE_MS);
    };

    const clearFilters = () => {
      const activeFilters = getActiveFilters(state.filters);
      state.filters = Object.fromEntries(FILTER_CATEGORIES.map((cat) => [cat.key, []]));
      state.searchQuery = "";
      state.difficultyFilter = [];
      state.visibleCount = INITIAL_RENDER_COUNT;
      setDrawerVisible(false);
      trackEvent("clear_filters", { count: activeFilters });
      applyAndRender();
    };

    const setupLoadMoreObserver = () => {
      const observer = new IntersectionObserver((entries) => {
        if (!entries[0]?.isIntersecting) return;
        const total = getSortedPokemon().length;
        if (state.visibleCount >= total) return;
        state.visibleCount = Math.min(state.visibleCount + RENDER_BATCH_SIZE, total);
        renderPokemonGrid();
      }, { rootMargin: "300px 0px" });
      observer.observe(els.loadMoreSentinel);
    };

    const initFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      state.filters = { ...state.filters, ...parseFiltersFromUrl(params) };
      state.searchQuery = params.get("search") ?? "";
      state.difficultyFilter = params.getAll("difficulty");
      const sortParam = params.get("sortBy");
      const savedSort = localStorage.getItem("pokedoku-sort");
      const candidate = sortParam || savedSort || "number-asc";
      state.sortBy = SORT_OPTIONS.has(candidate) ? candidate : "number-asc";
    };

    const bindEvents = () => {
      els.searchInput.addEventListener("input", (event) => {
        state.visibleCount = INITIAL_RENDER_COUNT;
        state.searchQuery = event.target.value;
        applyAndRender();
        trackSearchQuery("desktop");
      });
      els.searchInputDrawer.addEventListener("input", (event) => {
        state.visibleCount = INITIAL_RENDER_COUNT;
        state.searchQuery = event.target.value;
        applyAndRender();
        trackSearchQuery("drawer");
      });
      els.sortSelect.addEventListener("change", (event) => {
        state.sortBy = event.target.value;
        localStorage.setItem("pokedoku-sort", state.sortBy);
        state.visibleCount = INITIAL_RENDER_COUNT;
        const column = state.sortBy.startsWith("number")
          ? "number"
          : state.sortBy.startsWith("name")
            ? "name"
            : state.sortBy.startsWith("difficulty")
              ? "difficulty"
              : "recent-appearance";
        trackEvent("change_sort", { column, sort: state.sortBy });
        applyAndRender();
      });
      els.openDrawer.addEventListener("click", () => setDrawerVisible(true));
      els.closeDrawer.addEventListener("click", () => setDrawerVisible(false));
      els.drawerOverlay.addEventListener("click", () => setDrawerVisible(false));
      els.clearFilters.addEventListener("click", clearFilters);
      els.clearFiltersDrawer.addEventListener("click", clearFilters);
    };

    const init = async () => {
      initFromUrl();
      bindEvents();
      setupLoadMoreObserver();

      try {
        const pokemonRes = await fetch(`${import.meta.env.BASE_URL}data/pokemon.json?t=${Date.now()}`);
        state.pokemon = await pokemonRes.json();
        trackEvent("view_pokemon_list", { count: state.pokemon.length });
      } catch (error) {
        console.error("Failed to load Pokemon:", error);
      }

      try {
        const recentRes = await fetch(`${import.meta.env.BASE_URL}data/runtime/pokemon-last-usable.json?t=${Date.now()}`);
        const data = await recentRes.json();
        const byKeyId = new Map();
        const latestPuzzleDate = data.dateRange?.to;
        for (const item of data.items ?? []) {
          byKeyId.set(item.pokemonKeyId, toDaysSinceLastUsable(item, latestPuzzleDate));
        }
        state.daysSinceLastUsableByKeyId = byKeyId;
      } catch (error) {
        console.error("Failed to load Pokemon recent appearance:", error);
      }

      state.loading = false;
      applyAndRender();
    };

    init();
  </script>
</AppPageLayout>
