---
import AppPageLayout from "../../layouts/AppPageLayout.astro";
import PokemonDetailPage from "../../components/PokemonDetailPage.astro";
import { getPokemonBySlugMap, getPokemonList, getPokemonSlug } from "../../lib/data";

export function getStaticPaths() {
  return getPokemonList().map((pokemon) => ({
    params: { slug: getPokemonSlug(pokemon) },
  }));
}

const slug = Astro.params.slug ?? "";
const pokemon = getPokemonBySlugMap().get(slug);

if (!pokemon) {
  throw Astro.redirect("/pokemon-list/");
}

const statsKeyId = pokemon.formId ?? pokemon.id;

---

<AppPageLayout
  title={`${pokemon.name} | Pokedoku Helper`}
  description={`Details for ${pokemon.name}: type, region, evolution, and dex difficulty.`}
  path={`/pokemon/${slug}/`}
>
  <PokemonDetailPage pokemon={pokemon} slug={slug} statsKeyId={statsKeyId} />
</AppPageLayout>
