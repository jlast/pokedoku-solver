---
import fs from "node:fs";
import path from "node:path";
import AppPageLayout from "../../layouts/AppPageLayout.astro";
import PokemonDetailPage from "../../components/PokemonDetailPage.astro";
import { getPokemonBySlugMap, getPokemonList, getPokemonSlug } from "../../lib/data";

interface PokemonRuntimeStats {
  puzzlesAnalyzed: number;
  totalAppearances: {
    count: number;
    percentage: number;
  };
  lastUsable: {
    date: string;
    daysAgo: number;
  };
  categoryMatches: Array<{
    categoryId: string;
    occurrences: number;
  }>;
  combinationMatches: Array<{
    categories: string[];
    occurrences: number;
  }>;
}

export function getStaticPaths() {
  return getPokemonList().map((pokemon) => ({
    params: { slug: getPokemonSlug(pokemon) },
  }));
}

const slug = Astro.params.slug ?? "";
const pokemon = getPokemonBySlugMap().get(slug);

if (!pokemon) {
  throw Astro.redirect("/pokemon-list/");
}

const pokemonList = getPokemonList();
const relatedPokemon = pokemonList
  .filter((entry) => {
    if ((entry.formId ?? entry.id) === (pokemon.formId ?? pokemon.id)) return false;
    if (entry.evolutionStage && pokemon.evolutionStage && entry.evolutionStage === pokemon.evolutionStage) return true;
    return entry.types.some((type) => pokemon.types.includes(type));
  })
  .slice(0, 5);

const statsKeyId = pokemon.formId ?? pokemon.id;
const statsPath = path.resolve(process.cwd(), "..", "public", "data", "runtime", "pokemon", `${statsKeyId}-stats.json`);

let runtimeStats: PokemonRuntimeStats | null = null;
try {
  const rawStats = fs.readFileSync(statsPath, "utf8");
  const parsedStats = JSON.parse(rawStats) as Partial<PokemonRuntimeStats>;
  if (
    typeof parsedStats?.puzzlesAnalyzed === "number" &&
    typeof parsedStats?.totalAppearances?.count === "number" &&
    typeof parsedStats?.totalAppearances?.percentage === "number" &&
    typeof parsedStats?.lastUsable?.date === "string" &&
    typeof parsedStats?.lastUsable?.daysAgo === "number" &&
    Array.isArray(parsedStats?.categoryMatches) &&
    Array.isArray(parsedStats?.combinationMatches)
  ) {
    runtimeStats = {
      puzzlesAnalyzed: parsedStats.puzzlesAnalyzed,
      totalAppearances: parsedStats.totalAppearances,
      lastUsable: parsedStats.lastUsable,
      categoryMatches: parsedStats.categoryMatches,
      combinationMatches: parsedStats.combinationMatches,
    };
  }
} catch {
  runtimeStats = null;
}

---

<AppPageLayout
  title={`${pokemon.name} | Pokedoku Helper`}
  description={`Details for ${pokemon.name}: type, region, evolution, and dex difficulty.`}
  path={`/pokemon/${slug}/`}
>
  <PokemonDetailPage pokemon={pokemon} slug={slug} relatedPokemon={relatedPokemon} runtimeStats={runtimeStats} />
</AppPageLayout>
