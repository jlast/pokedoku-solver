---
import AppPageLayout from "../../layouts/AppPageLayout.astro";
import PokemonDetailPage from "../../components/PokemonDetailPage.astro";
import { getPokemonBySlugMap, getPokemonList, getPokemonSlug } from "../../lib/data";

export function getStaticPaths() {
  return getPokemonList().map((pokemon) => ({
    params: { slug: getPokemonSlug(pokemon) },
  }));
}

const slug = Astro.params.slug ?? "";
const pokemon = getPokemonBySlugMap().get(slug);

if (!pokemon) {
  throw Astro.redirect("/pokemon-list/");
}

const pokemonList = getPokemonList();
const relatedPokemon = pokemonList
  .filter((entry) => {
    if ((entry.formId ?? entry.id) === (pokemon.formId ?? pokemon.id)) return false;
    if (entry.evolutionStage && pokemon.evolutionStage && entry.evolutionStage === pokemon.evolutionStage) return true;
    return entry.types.some((type) => pokemon.types.includes(type));
  })
  .slice(0, 5);

const statsKeyId = pokemon.formId ?? pokemon.id;

---

<AppPageLayout
  title={`${pokemon.name} | Pokedoku Helper`}
  description={`Details for ${pokemon.name}: type, region, evolution, and dex difficulty.`}
  path={`/pokemon/${slug}/`}
>
  <PokemonDetailPage pokemon={pokemon} slug={slug} relatedPokemon={relatedPokemon} statsKeyId={statsKeyId} />
</AppPageLayout>
