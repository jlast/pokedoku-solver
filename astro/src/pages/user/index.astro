---
import AppPageLayout from "../../layouts/AppPageLayout.astro";
import { Footer } from "../../app/components/Footer";
import { Header } from "../../app/components/Header";
import { PokedexDashboardPageClient } from "../../app/pages/PokedexDashboardPageClient";
---

<AppPageLayout
  title="Pokedex Dashboard | Pokedoku Helper"
  description="Manage your personal Pokedex progress from your dashboard."
  path="/user/"
>
  <div class="min-h-screen overflow-x-hidden p-5">
    <Header
      title="Pokedex Dashboard"
      subtitle="Your signed-in space for personal dex progress and tools."
      currentPage="my-pokedex"
      client:load
    />
    <PokedexDashboardPageClient client:load />
    <Footer client:load />
  </div>
</AppPageLayout>
