---
import AppPageLayout from "../../layouts/AppPageLayout.astro";
import { Header } from "../../app/components/Header";
import { Footer } from "../../app/components/Footer";
import { TodayPageClient } from "../../app/pages/TodayPageClient";
import ContentSection from "../../components/shared/ContentSection.astro";
---

<AppPageLayout
  title="Pokedoku Answers Today – All 9 Solutions + Rarest Pokémon Picks"
  description="Get today's Pokedoku answers with all 9 solutions and strategic Pokémon picks to help optimize your Pokédex completion. Updated daily."
  path="/pokedoku-answers-today/"
>
  <div class="min-h-screen p-5">
    <Header
      title="Today's Pokedoku Answers"
      subtitle="Get all 9 Pokedoku answers for today with strategic Pokémon picks to optimize your Pokedex completion."
      showUpdatedDaily={true}
      alwaysShowSubheader={true}
      currentPage="today"
      client:load
    />

    <TodayPageClient client:load />

    <Footer />
  </div>
</AppPageLayout>
