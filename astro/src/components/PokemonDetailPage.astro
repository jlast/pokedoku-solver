---
import { Header } from "../app/components/Header";
import { Footer } from "../app/components/Footer";
import Badge from "./Badge.astro";
import Breadcrumb from "./Breadcrumb.astro";
import SectionCard from "./SectionCard.astro";
import { CategoryBadgeLink } from "../app/components/shared/CategoryBadgeLink";
import { parseCategoryId } from "../app/components/puzzle-stats/categoryUtils";
import { PokemonRuntimeStatsSectionsPanel, PokemonRuntimeStatsSummaryPanel, PokemonRuntimeStatsTimelinePanel } from "../app/components/pokemon-detail/PokemonRuntimeStatsPanel";
import {
  DEX_DIFFICULTY_COLORS,
  REGION_COLORS,
} from "../../../lib/shared/constants";
import { FILTER_CATEGORIES } from "../../../lib/shared/filters";
import type { Pokemon } from "@pokedoku-helper/shared-types";
import { slugify } from "../lib/slug";
import { getPokemonList, getPokemonSlug } from "../lib/data";

interface Props {
  pokemon: Pokemon;
  slug: string;
  statsKeyId: number;
}

type PokemonWithEvolution = Pokemon & {
  evolution?: {
    from?: number[];
    to?: number[];
  };
  learnedMoves?: string[];
  abilities?: string[];
};

const { pokemon, slug, statsKeyId } = Astro.props as Props;
const pokemonWithEvolution = pokemon as PokemonWithEvolution;
const dexNumber = `#${String(pokemon.id).padStart(3, "0")}`;
const rarityScore =
  typeof pokemon.dexDifficultyPercentile === "number"
    ? Math.round(pokemon.dexDifficultyPercentile * 100)
    : null;
const rarityDegrees = rarityScore === null ? 0 : Math.max(0, Math.min(360, Math.round((rarityScore / 100) * 360)));
const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Pokemon", href: "/pokemon-list/" },
  { label: pokemon.name },
];

const categorySlugSet = new Set(
  FILTER_CATEGORIES.flatMap((filterCategory) =>
    filterCategory.options.map((option) => slugify(option.name)),
  ),
);

function getCategoryHref(label: string): string | null {
  const slug = slugify(label);
  return categorySlugSet.has(slug) ? `/tools/category/${slug}/` : null;
}

const applicableCategoryIds = Array.from(
  new Set(
    FILTER_CATEGORIES.flatMap((filterCategory) =>
      filterCategory.options
        .filter((option) => option.filter(pokemon))
        .map((option) => `${filterCategory.key}:${option.name}`),
    ),
  ),
);
const topCategoryIds = applicableCategoryIds.filter((categoryId) => {
  const parsed = parseCategoryId(categoryId);
  return parsed.type !== "move" && parsed.type !== "ability";
});

const categoryLabel = pokemon.categories?.length ? pokemon.categories.join(", ") : "-";
const movesLabel = pokemonWithEvolution.learnedMoves?.length ? pokemonWithEvolution.learnedMoves.join(", ") : "-";
const abilitiesLabel = pokemonWithEvolution.abilities?.length ? pokemonWithEvolution.abilities.join(", ") : "-";
const pokemonByFormId = new Map<number, Pokemon>(
  getPokemonList().map((entry: Pokemon) => [entry.formId ?? entry.id, entry]),
);
const evolvesFrom = (pokemonWithEvolution.evolution?.from ?? [])
  .map((formId: number) => pokemonByFormId.get(formId))
  .filter((entry): entry is Pokemon => Boolean(entry));
const evolvesTo = (pokemonWithEvolution.evolution?.to ?? [])
  .map((formId: number) => pokemonByFormId.get(formId))
  .filter((entry): entry is Pokemon => Boolean(entry));
const alternativeForms = getPokemonList().filter((entry: Pokemon) => {
  if (entry.id !== pokemon.id) return false;
  return (entry.formId ?? entry.id) !== (pokemon.formId ?? pokemon.id);
});
const hasAlternativeForms = alternativeForms.length > 0;
const hasEvolutionLine =
  evolvesFrom.length > 0 || evolvesTo.length > 0 || hasAlternativeForms;

---

  <div class="min-h-screen px-4 py-6">
    <Header title={pokemon.name} subtitle={`Details for ${pokemon.name}: type, region, evolution, and dex difficulty.`} currentPage="pokemon-list" client:load />

    <main class="mx-auto w-full max-w-6xl px-2 pb-10">
      <Breadcrumb items={breadcrumbItems} />

      <section class="mb-4 grid gap-4 rounded-3xl border border-[var(--border)] bg-[var(--bg)] p-5 shadow-[0_16px_36px_rgba(15,23,42,0.08)] md:grid-cols-[190px_1fr]">
        <div class="flex min-h-[170px] items-center justify-center rounded-2xl border border-[var(--border)] bg-[var(--code-bg)]">
          {pokemon.sprite ? (
            <img src={pokemon.sprite} alt={pokemon.name} class="h-32 w-32 object-contain" loading="lazy" />
          ) : (
            <div class="text-4xl font-bold text-[var(--text-h)]">{pokemon.name.slice(0, 1)}</div>
          )}
        </div>

        <div>
          <div class="flex items-baseline gap-2">
            <h1 class="text-4xl font-bold leading-tight tracking-tight text-[var(--text-h)]">{pokemon.name}</h1>
            <span class="text-lg font-semibold text-[var(--text)]">{dexNumber}</span>
          </div>

          <div class="mt-3 flex flex-wrap gap-2">
            {topCategoryIds.map((categoryId) => {
              const parsed = parseCategoryId(categoryId);
              return <CategoryBadgeLink parsed={parsed} href={getCategoryHref(parsed.label)} />;
            })}
          </div>

          <div class="mt-4 grid gap-3 md:grid-cols-3">
            <article class="rounded-2xl border border-[var(--border)] bg-[var(--code-bg)] p-3 md:col-span-3">
              <span class="block text-sm text-[var(--text)]">Pokedoku Difficulty</span>
              <Badge text={pokemon.dexDifficulty ?? "Unknown"} color={DEX_DIFFICULTY_COLORS[pokemon.dexDifficulty ?? "Unknown"] ?? "#64748b"} />
              <small class="mt-1 block text-xs text-[var(--text)]">Based on usage frequency and category spread</small>
            </article>
            <article class="rounded-2xl border border-[var(--border)] bg-[var(--code-bg)] p-3">
              <span class="block text-sm text-[var(--text)]">National Dex</span>
              <strong class="text-[var(--text-h)]">#{pokemon.id}</strong>
            </article>
            <PokemonRuntimeStatsSummaryPanel statsKeyId={statsKeyId} client:load />
          </div>
        </div>
      </section>

      <section class="grid items-start gap-4 lg:grid-cols-2">
        <div class="grid gap-4">
          <div class="w-full lg:col-span-2">
            <PokemonRuntimeStatsTimelinePanel statsKeyId={statsKeyId} client:load />
          </div>

          <SectionCard title="Rarity score" class="lg:col-span-2">
            <div class="grid gap-4 md:grid-cols-[2fr_1fr]">
              <div>
                <div class="mt-2 flex items-center justify-center gap-3 sm:justify-start">
                  <div
                    class="grid h-32 w-32 place-items-center rounded-full"
                    style={`background: conic-gradient(from 0deg, #4f6fff 0deg, #70b9ff ${rarityDegrees}deg, #e7ebf7 ${rarityDegrees}deg, #e7ebf7 360deg);`}
                  >
                    <div class="grid h-24 w-24 place-items-center rounded-full bg-[var(--bg)] text-[var(--text-h)]">
                      <strong class="text-3xl leading-none font-bold">{rarityScore ?? "-"}</strong>
                    </div>
                  </div>
                  <span class="ml-2 text-sm font-semibold text-[var(--text)]">/100</span>
                </div>
                <p class="mt-2 text-left text-[var(--text)]">{rarityScore === null ? "Rarity data unavailable." : `Rarer than ${rarityScore}% of all pokemon`}</p>
              </div>
              <div class="flex items-center justify-center border-t border-[var(--border)] pt-3 md:border-t-0 md:border-l md:pl-4 md:pt-0">
                <Badge
                  text={pokemon.dexDifficulty ?? "Unknown"}
                  color={DEX_DIFFICULTY_COLORS[pokemon.dexDifficulty ?? ""] ?? "#64748b"}
                />
              </div>
            </div>
          </SectionCard>
          {hasEvolutionLine ? (
            <SectionCard title="Evolution line" class="lg:col-span-2">
              <div class="grid gap-4">
                {evolvesFrom.length > 0 ? (
                  <section>
                    <p class="mb-2 text-sm font-medium text-[var(--text)]">Evolves from</p>
                    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                      {evolvesFrom.map((entry: Pokemon) => (
                        <a
                          class="flex items-center gap-3 rounded-2xl border border-[var(--border)] bg-[var(--code-bg)] px-3 py-2 transition hover:border-[var(--accent-border)] hover:bg-[var(--accent-bg)]"
                          href={`/pokemon/${getPokemonSlug(entry)}/`}
                        >
                          {entry.sprite ? (
                            <img src={entry.sprite} alt={entry.name} class="h-12 w-12 object-contain" loading="lazy" />
                          ) : (
                            <div class="grid h-12 w-12 place-items-center rounded-xl bg-[var(--bg)] text-sm font-bold text-[var(--text-h)]">
                              {entry.name.slice(0, 1)}
                            </div>
                          )}
                          <span class="font-semibold text-[var(--text-h)]">{entry.name}</span>
                        </a>
                      ))}
                    </div>
                  </section>
                ) : null}

                {evolvesTo.length > 0 ? (
                  <section>
                    <p class="mb-2 text-sm font-medium text-[var(--text)]">Evolves to</p>
                    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                      {evolvesTo.map((entry: Pokemon) => (
                        <a
                          class="flex items-center gap-3 rounded-2xl border border-[var(--border)] bg-[var(--code-bg)] px-3 py-2 transition hover:border-[var(--accent-border)] hover:bg-[var(--accent-bg)]"
                          href={`/pokemon/${getPokemonSlug(entry)}/`}
                        >
                          {entry.sprite ? (
                            <img src={entry.sprite} alt={entry.name} class="h-12 w-12 object-contain" loading="lazy" />
                          ) : (
                            <div class="grid h-12 w-12 place-items-center rounded-xl bg-[var(--bg)] text-sm font-bold text-[var(--text-h)]">
                              {entry.name.slice(0, 1)}
                            </div>
                          )}
                          <span class="font-semibold text-[var(--text-h)]">{entry.name}</span>
                        </a>
                      ))}
                    </div>
                  </section>
                ) : null}

                {hasAlternativeForms ? (
                  <section>
                    <p class="mb-2 text-sm font-medium text-[var(--text)]">Alternative forms</p>
                    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                      {alternativeForms.map((entry: Pokemon) => (
                        <a
                          class="flex items-center gap-3 rounded-2xl border border-[var(--border)] bg-[var(--code-bg)] px-3 py-2 transition hover:border-[var(--accent-border)] hover:bg-[var(--accent-bg)]"
                          href={`/pokemon/${getPokemonSlug(entry)}/`}
                        >
                          {entry.sprite ? (
                            <img src={entry.sprite} alt={entry.name} class="h-12 w-12 object-contain" loading="lazy" />
                          ) : (
                            <div class="grid h-12 w-12 place-items-center rounded-xl bg-[var(--bg)] text-sm font-bold text-[var(--text-h)]">
                              {entry.name.slice(0, 1)}
                            </div>
                          )}
                          <span class="font-semibold text-[var(--text-h)]">{entry.name}</span>
                        </a>
                      ))}
                    </div>
                  </section>
                ) : null}
              </div>
            </SectionCard>
          ) : null}

        </div>

        <div class="grid gap-4">

        <div class="w-full lg:col-span-2">
          <PokemonRuntimeStatsSectionsPanel statsKeyId={statsKeyId} client:load />
        </div>
        <SectionCard title="Core details" class="lg:col-span-2">
          <ul class="grid gap-2">
            <li class="grid grid-cols-[120px_1fr] items-start gap-3 border-b border-[var(--border)] pb-2"><span class="text-[var(--text)]">Region</span><strong class="text-right" style={`color:${REGION_COLORS[pokemon.region ?? ""] ?? "#0f172a"};`}>{pokemon.region ?? "Unknown"}</strong></li>
            <li class="grid grid-cols-[120px_1fr] items-start gap-3 border-b border-[var(--border)] pb-2"><span class="text-[var(--text)]">Evolution stage</span><strong class="text-right text-[var(--text-h)]">{pokemon.evolutionStage ?? "Unknown"}</strong></li>
            <li class="grid grid-cols-[120px_1fr] items-start gap-3 border-b border-[var(--border)] pb-2"><span class="text-[var(--text)]">Categories</span><strong class="text-right break-words text-[var(--text-h)]">{categoryLabel}</strong></li>
            <li class="grid grid-cols-[120px_1fr] items-start gap-3 border-b border-[var(--border)] pb-2"><span class="text-[var(--text)]">Evolution trigger</span><strong class="text-right break-words text-[var(--text-h)]">{pokemon.evolutionTrigger?.join(", ") ?? "-"}</strong></li>
            <li class="grid grid-cols-[120px_1fr] items-start gap-3 border-b border-[var(--border)] pb-2"><span class="text-[var(--text)]">Moves</span><strong class="text-right break-words text-[var(--text-h)]">{movesLabel}</strong></li>
            <li class="grid grid-cols-[120px_1fr] items-start gap-3"><span class="text-[var(--text)]">Abilities</span><strong class="text-right break-words text-[var(--text-h)]">{abilitiesLabel}</strong></li>
          </ul>
        </SectionCard>

        <SectionCard title={`About ${pokemon.name}`} class="lg:col-span-2">
          <p class="text-[var(--text)]">
            {pokemon.name} is a {pokemon.types.join("/")}-type Pokemon from {pokemon.region ?? "an unknown region"}.
            {pokemon.evolutionStage ? ` It is classified as ${pokemon.evolutionStage.toLowerCase()}.` : ""}
            {pokemon.dexDifficulty ? ` In PokeDoku, its difficulty is ${pokemon.dexDifficulty.toLowerCase()}.` : ""}
          </p>
        </SectionCard>

        </div>
      </section>
    </main>

    <Footer client:load />
  </div>
