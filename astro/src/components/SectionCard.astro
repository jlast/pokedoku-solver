---
interface Props {
  title?: string;
  class?: string;
}

const { title = "", class: className = "" } = Astro.props as Props;
---

<article class={`rounded-3xl border border-[var(--border)] bg-[var(--bg)] p-4 shadow-[0_12px_28px_rgba(15,23,42,0.06)] ${className}`}>
  <div class="mb-2 flex items-start justify-between gap-3">
    <div class="min-w-0">
      <slot name="title">
        <h2 class="text-xl font-semibold tracking-tight text-[var(--text-h)]">{title}</h2>
      </slot>
    </div>
    <div class="shrink-0">
      <slot name="headerRight" />
    </div>
  </div>
  <slot />
</article>
