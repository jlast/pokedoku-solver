---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="relative inline-block group">
  <button
    type="button"
    class="flex items-center justify-center w-5 h-5 rounded-full border border-gray-400 text-gray-600 text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-blue-500"
    aria-label="More info"
  >
    i
  </button>

  <div
    class="absolute z-10 bottom-full left-1/2 -translate-x-1/2 mb-2 
           w-max max-w-xs px-3 py-2 rounded-md 
           bg-gray-800 text-white text-sm text-center
           opacity-0 pointer-events-none 
           transition-opacity duration-200
           group-hover:opacity-100 group-hover:pointer-events-auto
           group-focus-within:opacity-100 group-focus-within:pointer-events-auto"
  >
    {text}
  </div>
</div>
