---
interface Props {
  text: string;
}

const { text } = Astro.props;
const id = `info-${crypto.randomUUID()}`;
---

<span class="relative inline-flex" data-info>
  <button
    type="button"
    class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-xs font-semibold leading-none text-slate-600 transition-colors hover:border-slate-400 hover:text-slate-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
    aria-label="More information"
    aria-expanded="false"
    aria-controls={id}
    data-info-button
  >
    <span class="font-serif text-sm font-bold">i</span>
  </button>

  <span
    id={id}
    role="dialog"
    class="absolute left-1/2 top-full z-20 mt-2 hidden w-72 -translate-x-1/2 rounded-xl bg-slate-900 px-3 py-2 text-xs font-medium leading-relaxed text-white shadow-lg"
    data-info-panel
  >
    {text}
  </span>
</span>

<script is:inline>
  document.addEventListener("click", function (event) {
    const clickedButton = event.target.closest("[data-info-button]");
    const clickedPanel = event.target.closest("[data-info-panel]");

    document.querySelectorAll("[data-info]").forEach(function (wrapper) {
      const button = wrapper.querySelector("[data-info-button]");
      const panel = wrapper.querySelector("[data-info-panel]");

      if (!button || !panel) return;

      const isThisButton = clickedButton === button;
      const isOpen = button.getAttribute("aria-expanded") === "true";

      if (clickedPanel && wrapper.contains(clickedPanel)) {
        return;
      }

      const shouldOpen = isThisButton && !isOpen;

      button.setAttribute("aria-expanded", String(shouldOpen));
      panel.hidden = !shouldOpen;
      panel.classList.toggle("hidden", !shouldOpen);
    });
  });
</script>
