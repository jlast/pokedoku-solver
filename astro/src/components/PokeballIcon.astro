---
const { tone = "pokeball", class: className = "" } = Astro.props;

const toneClass = {
  pokeball: "text-red-500",
  greatball: "text-blue-600",
  ultraball: "text-yellow-400",
  masterball: "text-purple-400",
  premierball: "text-slate-400",
  beastball: "text-slate-700",
  cherishball: "text-red-700",
}[tone] ?? "text-red-500";

---

<svg class:list={[toneClass, className]} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <circle cx="12" cy="12" r="9" stroke="rgb(30 41 59)" stroke-width="1.35"></circle>
  <path d="M3 12h18" stroke="rgb(30 41 59)" stroke-width="1.35" stroke-linecap="round"></path>
  <path d="M5.2 12a6.8 6.8 0 0 1 13.6 0" class="fill-current"></path>
  <path data-ball-bottom d="M5.2 12a6.8 6.8 0 0 0 13.6 0" fill={tone === "cherishball" ? "currentColor" : "white"}></path>
  <circle cx="12" cy="12" r="2.5" fill="white" stroke="rgb(30 41 59)" stroke-width="1.1"></circle>
</svg>
