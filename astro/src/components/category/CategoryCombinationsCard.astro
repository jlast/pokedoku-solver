---
import CategoryIconBadge from "../CategoryIconBadge.astro";
import { parseCategoryId } from "../../app/components/puzzle-stats/categoryUtils";
import type { CategoryRuntimeCombinationMatch } from "../../lib/data";

interface Props {
  combinations: CategoryRuntimeCombinationMatch[];
}

const { combinations } = Astro.props;
---

<article class="rounded-3xl border border-slate-200 bg-white p-4 shadow-[0_12px_28px_rgba(15,23,42,0.06)]">
  <h2 class="text-xl font-semibold tracking-tight text-slate-900">Most common combinations</h2>
  {combinations.length > 0 ? (
    <ul class="mt-3 list gap-2">
      {combinations.map((match) => {
        const left = parseCategoryId(match.categories[0]);
        const right = parseCategoryId(match.categories[1]);
        return (
          <li class="rounded-2xl border border-slate-200 bg-slate-50/70 p-2.5">
            <div class="mb-2 inline-flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center gap-2">
                <CategoryIconBadge parsed={left} />
                {left.label}
              </span>
              <span class="muted">+</span>
              <span class="inline-flex items-center gap-2">
                <CategoryIconBadge parsed={right} />
                {right.label}
              </span>
            </div>
            <div class="text-right">
              <span class="inline-flex rounded-full border border-slate-200 bg-white px-2 py-0.5 text-xs font-semibold text-slate-700">{match.occurrences} times</span>
            </div>
          </li>
        );
      })}
    </ul>
  ) : (
    <p class="mt-2 text-slate-500">No combination history available yet.</p>
  )}
</article>
