---
import { parseCategoryId, getCategoryBarColor } from "../../app/components/puzzle-stats/categoryUtils";
import { CombinationRows, type CombinationRow } from "../../app/components/shared/CombinationRows";
import type { CategoryRuntimeCombinationMatch } from "../../lib/data";

interface Props {
  combinations: CategoryRuntimeCombinationMatch[];
  puzzlesAnalyzed?: number;
}

const { combinations, puzzlesAnalyzed = 0 } = Astro.props;

const rows: CombinationRow[] = combinations.map((match) => {
  const left = parseCategoryId(match.categories[0]);
  const right = parseCategoryId(match.categories[1]);
  const percent = puzzlesAnalyzed > 0 ? (match.occurrences / puzzlesAnalyzed) * 100 : 0;

  return {
    leftRaw: left.raw,
    rightRaw: right.raw,
    percent,
    widthPercent: percent,
    gradient: `linear-gradient(90deg, ${getCategoryBarColor(left)}, ${getCategoryBarColor(right)})`,
  };
});

const maxPercent = rows.reduce((max, row) => Math.max(max, row.percent), 0);
for (const row of rows) {
  row.widthPercent = maxPercent > 0 ? (row.percent / maxPercent) * 100 : 0;
}
---

<article class="rounded-3xl border border-slate-200 bg-white p-4 shadow-[0_12px_28px_rgba(15,23,42,0.06)]">
  <h2 class="text-xl text-left font-semibold tracking-tight text-slate-900">Most common combinations</h2>
  {rows.length > 0 ? (
    <div class="mt-3">
      <CombinationRows rows={rows} />
    </div>
  ) : (
    <p class="mt-2 text-slate-500">No combination history available yet.</p>
  )}
</article>
