---
import { PokemonCard } from "../../app/components/shared/PokemonCard";
import { slugify } from "../../lib/slug";
import InfoTooltipIcon from "../shared/InfoTooltipIcon.astro";
import SectionCard from "../SectionCard.astro";
import type { Pokemon } from "@pokedoku-helper/shared-types";

interface Props {
  pokemon: Pokemon[];
  category: string;
  categoryType: string;
  seeAllHref?: string;
}

const { pokemon, categoryType, category, seeAllHref } = Astro.props;
const resolvedSeeAllHref = seeAllHref ?? `/pokemon-list/?${categoryType}=${category}&sortBy=difficulty-asc`;
---

<SectionCard>
  <Fragment slot="title">
    <h2 class="inline-flex items-center gap-2 text-xl font-semibold tracking-tight text-slate-900">
      Best picks
      <InfoTooltipIcon text="These Pokémon appear in the fewest categories, but when they do appear, they have a lot of competition. Strong picks if you want safe, widely valid answers." />
    </h2>
  </Fragment>
  <a slot="headerRight" href={resolvedSeeAllHref} class="underline text-sm text-slate-600">
    See all Pokemon
  </a>
  {pokemon.length > 0 ? (
    <div class="pokemon-grid mt-3">
      {pokemon.slice(0, 4).map((entry) => (
        <PokemonCard pokemon={entry} href={`/pokemon/${slugify(entry.name)}-${entry.formId ?? entry.id}/`} />
      ))}
    </div>
  ) : (
    <div class="mt-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-600">
      No Pokemon currently match this category combination. Try another category or browse all Pokemon.
    </div>
  )}
</SectionCard>
