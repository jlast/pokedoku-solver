---
import Badge from "../Badge.astro";
import { DEX_DIFFICULTY_COLORS, TYPE_COLORS } from "../../../../lib/shared/constants";
import { getPokemonSlug, type Pokemon } from "../../lib/data";

interface Props {
  pokemon: Pokemon[];
  category: string;
  categoryType: string;
  seeAllHref?: string;
}

const { pokemon, categoryType, category, seeAllHref } = Astro.props;
const resolvedSeeAllHref = seeAllHref ?? `/pokemon-list/?${categoryType}=${category}`;
---

<article class="rounded-3xl border border-slate-200 bg-white p-4 shadow-[0_12px_28px_rgba(15,23,42,0.06)]">
  <div class="flex justify-between w-full">
    <h2 class="text-xl font-semibold tracking-tight text-slate-900">Best picks</h2>
    <a href={resolvedSeeAllHref} class="underline text-sm text-slate-600">
        See all Pokemon
    </a>
  </div>
  <div class="pokemon-grid mt-3">
    {pokemon.slice(0, 4).map((entry) => (
      <a
        href={`/pokemon/${getPokemonSlug(entry)}/`}
        class="pokemon-card block no-underline"
      >
        {entry.sprite ? (
          <img
            src={entry.sprite}
            alt=""
            class="pokemon-sprite"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
          />
        ) : (
          <div class="pokemon-sprite-placeholder" />
        )}
        <div class="pokemon-card-info">
          <div class="pokemon-card-name">{entry.name}</div>
          <div class="pokemon-card-id">#{entry.id}</div>
          <div class="pokemon-types">
            {entry.types.map((type) => (
              <span class="type-badge" style={{ backgroundColor: TYPE_COLORS[type!] }}>
                {type}
              </span>
            ))}
          </div>
          {entry.dexDifficulty ? (
            <span
              class="dex-difficulty-badge"
              style={{ backgroundColor: DEX_DIFFICULTY_COLORS[entry.dexDifficulty] }}
            >
              {entry.dexDifficulty}
            </span>
          ) : (
            <Badge text="Unknown" color="#64748b" />
          )}
        </div>
      </a>
    ))}
  </div>
</article>
