---
import CategoryIconBadge from "../CategoryIconBadge.astro";
import { parseCategoryId } from "../../app/components/puzzle-stats/categoryUtils";
import type { CategoryPageData } from "../../lib/data";

interface Props {
  groups: Array<{ type: string; label: string; items: CategoryPageData[] }>;
  activeSlug: string | string[];
}

const { groups, activeSlug } = Astro.props;
const activeSlugs = Array.isArray(activeSlug) ? activeSlug : [activeSlug];
const activeEntries = groups.flatMap((group) => group.items).filter((entry) => activeSlugs.includes(entry.slug));
const activeSlugsJson = JSON.stringify(activeSlugs);
---

<aside class="rounded-3xl border border-slate-200 bg-gradient-to-b from-white to-slate-50 p-4 shadow-[0_16px_34px_rgba(15,23,42,0.08)] lg:sticky lg:top-4" data-category-sidebar data-active-slugs={activeSlugsJson}>
  <div class="mb-3 px-1 py-1 hidden lg:block">
    <h2 class="m-0 text-xl font-semibold tracking-tight text-slate-900">Categories</h2>
  </div>

  <div class="mb-3 lg:hidden">
    <button
      id="category-mobile-trigger"
      type="button"
      aria-expanded="false"
      aria-controls="category-mobile-sheet"
      class="flex w-full items-center justify-between gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-left shadow-sm"
    >
      <span class="inline-flex min-w-0 items-center gap-2 text-slate-900">
        { activeEntries.map((entry) => (
          <CategoryIconBadge parsed={parseCategoryId(entry.key)} />
          <span class="truncate text-sm font-medium mr-2">{entry?.label ?? "Select category"}</span>
        ))}
      </span>
      <span class="text-slate-400">▾</span>
    </button>
  </div>

  <div class="mb-3 hidden lg:block">
    <label for="category-sidebar-search" class="sr-only">Search categories</label>
    <input
      id="category-sidebar-search"
      type="search"
      placeholder="Search categories..."
      class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-800 outline-none ring-0 transition focus:border-sky-300 focus:shadow-[0_0_0_3px_rgba(56,189,248,0.15)]"
    />
  </div>

  <div class="hidden gap-4 lg:grid" id="category-desktop-list">
      <section class="grid gap-2" data-category-group>
        <h3 class="px-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500">Selected</h3>
        <ul class="list gap-1.5">
        {
          activeEntries.map((activeEntry) => (
            <li class="mb-1 flex w-full min-w-0 items-stretch">
              <div class={`mr-[1px] min-w-0 flex-1 rounded-xl border border-sky-300 bg-sky-50/80 shadow-[0_10px_20px_rgba(14,116,144,0.16)] ${activeEntries.length === 2 ? "rounded-e-none" : ""}`}>
                <a href={`/category/${activeEntry.slug}/`} class="inline-flex w-full min-w-0 items-center gap-2 px-3 py-2 text-slate-800 no-underline">
                  <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full ring-1 ring-sky-300 bg-sky-100">
                    <CategoryIconBadge parsed={parseCategoryId(activeEntry.key)} />
                  </span>
                  <span class="truncate text-sm font-medium">{activeEntry.label}</span>
                </a>
              </div>
              {activeEntries.length === 2 ? (
                <button
                  type="button"
                  data-remove-slug={activeEntry.slug}
                  class="inline-flex w-8 shrink-0 items-center justify-center rounded-e-xl border border-slate-200 bg-white text-slate-700 hover:-translate-y-px hover:border-slate-300 hover:shadow-sm cursor-pointer"
                  aria-label={`Remove ${activeEntry.label}`}
                >
                  -
                </button>
              ) : null}
            </li>
          ))
        }
        </ul>
      </section>

    {groups.map((group) => (
      <section class="grid gap-2" data-category-group>
        <h3 class="px-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500">{group.label}</h3>
        <ul class="list gap-1.5">
          {group.items.map((entry) => {
            const parsed = parseCategoryId(entry.key);
            const isActive = activeSlugs.includes(entry.slug);

            return (
              <li data-category-item data-search-label={entry.label.toLowerCase()} class="mb-1 flex w-full min-w-0 items-stretch">
                <div
                  class={`mr-[1px] min-w-0 flex-1 rounded-xl border transition-all duration-150 ${!isActive && activeSlugs.length === 1 ? "rounded-e-none" : ""} ${isActive ? "border-sky-300 bg-sky-50/80 shadow-[0_10px_20px_rgba(14,116,144,0.16)]" : "border-slate-200 bg-white hover:-translate-y-px hover:border-slate-300 hover:shadow-sm"}`}
                >
                  <a href={`/category/${entry.slug}/`} class="inline-flex w-full min-w-0 items-center gap-2 px-3 py-2 text-slate-800 no-underline">
                    <span class={`inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full ring-1 ${isActive ? "ring-sky-300 bg-sky-100" : "ring-slate-200 bg-slate-50"}`}>
                      <CategoryIconBadge parsed={parsed} />
                    </span>
                    <span class="truncate text-sm font-medium">{entry.label}</span>
                  </a>
                </div>
                {!isActive && activeSlugs.length === 1 ? (
                  <a href={`/category/${activeSlugs[0]}/${entry.slug}/`}
                    class="inline-flex w-8 shrink-0 items-center justify-center rounded-e-xl border border-slate-200 bg-white text-slate-700 hover:-translate-y-px hover:border-slate-300 hover:shadow-sm"
                    aria-label={`Add ${entry.label}`}
                  >
                    +
                  </a>
                ) : null}
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>

  <div id="category-mobile-overlay" class="fixed inset-0 z-[1200] hidden bg-slate-900/45"></div>
  <div id="category-mobile-sheet" role="dialog" aria-modal="true" aria-label="Category picker" class="fixed inset-x-0 bottom-0 z-[1210] hidden max-h-[82vh] translate-y-full rounded-t-3xl border border-slate-200 bg-white shadow-[0_-16px_40px_rgba(15,23,42,0.24)] transition-transform duration-200 ease-out">
    <div class="mx-auto mt-2 h-1.5 w-16 rounded-full bg-slate-200"></div>
    <div class="flex items-center justify-between px-4 pb-2 pt-3">
      <h2 class="m-0 text-2xl font-semibold tracking-tight text-slate-900">Categories</h2>
      <button id="category-mobile-close" type="button" class="grid h-9 w-9 place-items-center rounded-full border border-slate-200 text-lg text-slate-500">×</button>
    </div>
    <div class="px-4 pb-2">
      <label for="category-mobile-search" class="sr-only">Search categories</label>
      <input id="category-mobile-search" type="search" placeholder="Search categories..." class="w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-800 outline-none ring-0 transition focus:border-sky-300 focus:shadow-[0_0_0_3px_rgba(56,189,248,0.15)]" />
    </div>
    <div class="max-h-[56vh] overflow-auto px-4 pb-3" id="category-mobile-list">
      <section class="mb-4 grid gap-2" data-mobile-category-group>
        <h3 class="px-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500">Selected</h3>
        <ul class="list gap-1.5">
          {activeEntries.map((activeEntry) => (
            <li class="mb-1 flex w-full min-w-0 items-stretch">
              <div class={`mr-[1px] min-w-0 flex-1 rounded-xl border border-sky-300 bg-sky-50/80 shadow-[0_10px_20px_rgba(14,116,144,0.16)] ${activeEntries.length === 2 ? "rounded-e-none" : ""}`}>
                <a
                  href={`/category/${activeEntry.slug}/`}
                  data-mobile-category-item
                  data-search-label={activeEntry.label.toLowerCase()}
                  data-slug={activeEntry.slug}
                  class="flex w-full items-center justify-between gap-3 px-3 py-2 text-left no-underline"
                >
                  <span class="inline-flex min-w-0 items-center gap-2 text-slate-900">
                    <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full ring-1 ring-sky-300 bg-sky-100">
                      <CategoryIconBadge parsed={parseCategoryId(activeEntry.key)} />
                    </span>
                    <span class="truncate text-base font-medium">{activeEntry.label}</span>
                  </span>
                  <span class="text-blue-600">✓</span>
                </a>
              </div>
              {activeEntries.length === 2 ? (
                <button type="button" data-mobile-remove-slug={activeEntry.slug} class="inline-flex w-8 shrink-0 items-center justify-center rounded-e-xl border border-slate-200 bg-white text-slate-700 cursor-pointer">-</button>
              ) : null}
            </li>
          ))}
        </ul>
      </section>
      {groups.map((group) => (
        <section class="mb-4 grid gap-2" data-mobile-category-group>
          <h3 class="px-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500">{group.label}</h3>
          <ul class="list gap-1.5">
            {group.items.map((entry) => {
              const parsed = parseCategoryId(entry.key);
              const isActive = activeSlugs.includes(entry.slug);
              return (
                <li data-mobile-category-item-wrap data-search-label={entry.label.toLowerCase()} class="mb-1 flex w-full min-w-0 items-stretch">
                  <div class={`mr-[1px] min-w-0 flex-1 rounded-xl border transition-all duration-150 ${!isActive && activeSlugs.length === 1 ? "rounded-e-none" : ""} ${isActive ? "border-sky-300 bg-sky-50/80" : "border-slate-200 bg-white"}`}>
                    <a
                      href={`/category/${entry.slug}/`}
                      data-mobile-category-item
                      data-slug={entry.slug}
                      data-search-label={entry.label.toLowerCase()}
                      class="flex w-full cursor-pointer items-center justify-between gap-3 px-3 py-2 text-left no-underline"
                    >
                      <span class="inline-flex min-w-0 items-center gap-2 text-slate-900">
                        <span class={`inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full ring-1 ${isActive ? "ring-sky-300 bg-sky-100" : "ring-slate-200 bg-slate-50"}`}>
                          <CategoryIconBadge parsed={parsed} />
                        </span>
                        <span class="truncate text-base font-medium">{entry.label}</span>
                      </span>
                      <span class={`text-blue-600 ${isActive ? "" : "hidden"}`} data-mobile-check>✓</span>
                    </a>
                  </div>
                  {!isActive && activeSlugs.length === 1 ? (
                    <button type="button" data-mobile-add-slug={entry.slug} class="inline-flex w-8 shrink-0 items-center justify-center rounded-e-xl border border-slate-200 bg-white text-slate-700">+</button>
                  ) : null}
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>
  </div>
</aside>

<script>
  const root = document.querySelector("[data-category-sidebar]");
  const searchInput = document.getElementById("category-sidebar-search");
  const mobileSearch = document.getElementById("category-mobile-search");
  const mobileTrigger = document.getElementById("category-mobile-trigger");
  const mobileSheet = document.getElementById("category-mobile-sheet");
  const mobileOverlay = document.getElementById("category-mobile-overlay");
  const mobileClose = document.getElementById("category-mobile-close");
  const initialActiveSlugs = root instanceof HTMLElement ? (root.dataset.activeSlugs ?? "[]") : "[]";
  let selectedSlugs: string[] = [];
  try {
    const parsed = JSON.parse(initialActiveSlugs);
    if (Array.isArray(parsed)) selectedSlugs = parsed.filter((value) => typeof value === "string");
  } catch {
    selectedSlugs = [];
  }

  const goSingle = (slug: string) => {
    window.location.href = `/category/${slug}/`;
  };

  const goPair = (left: string, right: string) => {
    window.location.href = `/category/${left}/${right}/`;
  };

  if (searchInput instanceof HTMLInputElement) {
    const groups = Array.from(document.querySelectorAll("[data-category-group]"));
    const items = Array.from(document.querySelectorAll("[data-category-item]"));

    const applyFilter = () => {
      const query = searchInput.value.trim().toLowerCase();

      for (const item of items) {
        const label = item.getAttribute("data-search-label") ?? "";
        const matches = query.length === 0 || label.includes(query);
        item.classList.toggle("hidden", !matches);
      }

      for (const group of groups) {
        const visibleItems = group.querySelectorAll("[data-category-item]:not(.hidden)").length;
        group.classList.toggle("hidden", visibleItems === 0);
      }
    };

    searchInput.addEventListener("input", applyFilter);
  }

  if (mobileSearch instanceof HTMLInputElement) {
    const groups = Array.from(document.querySelectorAll("[data-mobile-category-group]"));
    const items = Array.from(document.querySelectorAll("[data-mobile-category-item-wrap]"));

    const applyMobileFilter = () => {
      const query = mobileSearch.value.trim().toLowerCase();
      for (const item of items) {
        const label = item.getAttribute("data-search-label") ?? "";
        const matches = query.length === 0 || label.includes(query);
        item.classList.toggle("hidden", !matches);
      }
      for (const group of groups) {
        const visibleItems = group.querySelectorAll("[data-mobile-category-item-wrap]:not(.hidden)").length;
        const isSelectedGroup = group.querySelector("h3")?.textContent?.trim().toLowerCase() === "selected";
        if (isSelectedGroup) continue;
        group.classList.toggle("hidden", visibleItems === 0);
      }
    };

    mobileSearch.addEventListener("input", applyMobileFilter);
  }

  const openSheet = () => {
    if (!(mobileSheet instanceof HTMLElement) || !(mobileOverlay instanceof HTMLElement) || !(mobileTrigger instanceof HTMLElement)) return;
    mobileOverlay.classList.remove("hidden");
    mobileSheet.classList.remove("hidden");
    requestAnimationFrame(() => {
      mobileSheet.classList.remove("translate-y-full");
    });
    mobileTrigger.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  const closeSheet = () => {
    if (!(mobileSheet instanceof HTMLElement) || !(mobileOverlay instanceof HTMLElement) || !(mobileTrigger instanceof HTMLElement)) return;
    mobileSheet.classList.add("translate-y-full");
    mobileTrigger.setAttribute("aria-expanded", "false");
    window.setTimeout(() => {
      mobileOverlay.classList.add("hidden");
      mobileSheet.classList.add("hidden");
    }, 180);
    document.body.style.overflow = "";
  };

  if (mobileTrigger instanceof HTMLElement) {
    mobileTrigger.addEventListener("click", openSheet);
  }

  if (mobileClose instanceof HTMLElement) {
    mobileClose.addEventListener("click", closeSheet);
  }

  if (mobileOverlay instanceof HTMLElement) {
    mobileOverlay.addEventListener("click", closeSheet);
  }

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeSheet();
  });

  const mobileList = document.getElementById("category-mobile-list");
  if (mobileList instanceof HTMLElement) {
    mobileList.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const removeButton = target.closest("[data-mobile-remove-slug]");
      if (removeButton instanceof HTMLElement) {
        event.stopPropagation();
        const removeSlug = removeButton.getAttribute("data-mobile-remove-slug");
        if (!removeSlug) return;
        if (selectedSlugs.length === 2) {
          const remaining = selectedSlugs.find((slug) => slug !== removeSlug);
          if (remaining) goSingle(remaining);
        }
        return;
      }
      const addButton = target.closest("[data-mobile-add-slug]");
      if (addButton instanceof HTMLElement) {
        event.stopPropagation();
        const addSlug = addButton.getAttribute("data-mobile-add-slug");
        if (!addSlug || selectedSlugs.length !== 1) return;
        goPair(selectedSlugs[0], addSlug);
        return;
      }
      const button = target.closest("[data-mobile-category-item]");
      if (!(button instanceof HTMLElement)) return;
      const nextSlug = button.getAttribute("data-slug");
      if (!nextSlug) return;
      event.preventDefault();
      if (selectedSlugs.length === 1 && nextSlug === selectedSlugs[0]) {
        closeSheet();
        return;
      }
      if (selectedSlugs.length === 1) {
        goSingle(nextSlug);
        return;
      }
      if (selectedSlugs.length === 2) {
        if (selectedSlugs.includes(nextSlug)) {
          closeSheet();
          return;
        }
        goSingle(nextSlug);
      }
    });
  }

  const desktopRoot = document.getElementById("category-desktop-list");
  if (desktopRoot instanceof HTMLElement) {
    desktopRoot.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const addButton = target.closest("[data-add-slug]");
      if (addButton instanceof HTMLElement) {
        event.preventDefault();
        const addSlug = addButton.getAttribute("data-add-slug");
        if (!addSlug || selectedSlugs.length !== 1) return;
        goPair(selectedSlugs[0], addSlug);
        return;
      }
      const removeButton = target.closest("[data-remove-slug]");
      if (removeButton instanceof HTMLElement) {
        event.preventDefault();
        const removeSlug = removeButton.getAttribute("data-remove-slug");
        if (!removeSlug || selectedSlugs.length !== 2) return;
        const remaining = selectedSlugs.find((slug) => slug !== removeSlug);
        if (remaining) goSingle(remaining);
      }
    });
  }
</script>
