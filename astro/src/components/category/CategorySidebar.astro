---
import CategoryIconBadge from "../CategoryIconBadge.astro";
import { parseCategoryId } from "../../app/components/puzzle-stats/categoryUtils";
import type { CategoryPageData } from "../../lib/data";

interface Props {
  groups: Array<{ type: string; label: string; items: CategoryPageData[] }>;
  activeSlug: string;
}

const { groups, activeSlug } = Astro.props;
---

<aside class="max-h-[75vh] overflow-auto rounded-3xl border border-slate-200 bg-white p-4 shadow-[0_12px_28px_rgba(15,23,42,0.06)] lg:sticky lg:top-4">
  <h2 class="mt-0 text-xl font-semibold tracking-tight text-slate-900">Categories</h2>
  <div class="mt-3 grid gap-4">
    {groups.map((group) => (
      <section class="grid gap-2">
        <h3 class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">{group.label}</h3>
        <ul class="list gap-1.5">
          {group.items.map((entry) => {
            const parsed = parseCategoryId(entry.key);
            const isActive = entry.slug === activeSlug;

            return (
              <li
                class={`rounded-xl border bg-white transition-all duration-150 hover:-translate-y-px hover:shadow-sm ${isActive ? "border-blue-200 bg-blue-50/70" : "border-slate-200"}`}
              >
                <a href={`/category/${entry.slug}/`} class="flex items-center justify-between gap-3 px-3 py-2 no-underline">
                  <span class="inline-flex items-center gap-2 text-slate-800">
                    <CategoryIconBadge parsed={parsed} />
                    <span>{entry.label}</span>
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>
</aside>
