---
interface Props {
  title: string;
  open?: boolean;
  detailsClass?: string;
  summaryClass?: string;
  contentClass?: string;
  analyticsEvent?: string;
  analyticsLocation?: string;
  analyticsTarget?: string;
  analyticsValue?: string;
}

const {
  title,
  open = false,
  detailsClass = "",
  summaryClass = "",
  contentClass = "",
  analyticsEvent,
  analyticsLocation,
  analyticsTarget,
  analyticsValue,
} = Astro.props;
---

<details
  class:list={["group", detailsClass]}
  open={open}
  data-collapsible-analytics-event={analyticsEvent}
  data-collapsible-analytics-location={analyticsLocation}
  data-collapsible-analytics-target={analyticsTarget}
  data-collapsible-analytics-value={analyticsValue}
>
  <summary
    class:list={[
      "flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 font-extrabold text-[var(--text-h)] transition-colors hover:bg-[var(--accent-bg)] [&::-webkit-details-marker]:hidden",
      summaryClass,
    ]}
  >
    <span>{title}</span>
    <svg
      class="h-4 w-4 shrink-0 text-[var(--text)] transition-transform duration-200 group-open:rotate-180"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
    >
      <path d="m5 7.5 5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </summary>
  <div class={contentClass}>
    <slot />
  </div>
</details>

<script>
  // @ts-nocheck
  const trackEvent = (name, metadata) => {
    if (window.pokedokuAnalytics?.trackEvent) {
      window.pokedokuAnalytics.trackEvent(name, metadata);
    }
  };

  document
    .querySelectorAll("[data-collapsible-analytics-event]")
    .forEach((element) => {
      if (element.dataset.analyticsBound === "true") return;
      element.dataset.analyticsBound = "true";

      element.addEventListener("toggle", () => {
        const eventName = element.getAttribute("data-collapsible-analytics-event");
        if (!eventName) return;

        trackEvent(eventName, {
          location: element.getAttribute("data-collapsible-analytics-location") || undefined,
          target: element.getAttribute("data-collapsible-analytics-target") || undefined,
          value: element.getAttribute("data-collapsible-analytics-value") || undefined,
          enabled: element.open,
        });
      });
    });
</script>
