---
interface Props {
  text: string;
  color: string;
  class?: string;
}

const { text, color, class: className = "" } = Astro.props;
---

<span
  class={`inline-flex rounded-full px-3 py-1 text-xs font-bold tracking-wide text-white ${className}`}
  style={`background:${color};`}
>
  {text}
</span>
